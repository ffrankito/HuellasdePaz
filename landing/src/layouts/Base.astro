---
export interface Props {
  title?: string
  description?: string
}
const {
  title = 'Huellas de Paz — Crematorio y Cementerio de Mascotas',
  description = 'El primer crematorio de mascotas con habilitación formal en Rosario. Planes de previsión, cremación individual y comunitaria, cementerio parque.',
} = Astro.props
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <style>
      #paw-canvas {
        position: fixed;
        inset: 0;
        z-index: 0;
        pointer-events: none;
      }
      body {
        background-color: #f5f2ee;
        margin: 0;
      }
      body > *:not(#paw-canvas) {
        position: relative;
        z-index: 1;
      }
    </style>
  </head>
  <body>
    <canvas id="paw-canvas"></canvas>
    <slot />

    <script is:inline>
    (function(){
      const canvas = document.getElementById('paw-canvas')
      const ctx    = canvas.getContext('2d')
      let W, H, paws = [], mouse = {x:-9999,y:-9999}

      const PALETTE = [
        [45,138,84],
        [77,184,122],
        [170,223,194],
        [107,98,89],
        [168,159,148],
      ]

      function resize(){
        W = canvas.width  = window.innerWidth
        H = canvas.height = window.innerHeight
      }
      resize()
      window.addEventListener('resize', resize)
      window.addEventListener('mousemove', e => { mouse.x=e.clientX; mouse.y=e.clientY })
      window.addEventListener('touchmove', e => { mouse.x=e.touches[0].clientX; mouse.y=e.touches[0].clientY }, {passive:true})

      function drawPaw(x, y, s, angle, r, g, b, alpha){
        ctx.save()
        ctx.translate(x, y)
        ctx.rotate(angle)
        ctx.globalAlpha = alpha
        ctx.fillStyle = `rgb(${r},${g},${b})`
        /* palma */
        ctx.beginPath()
        ctx.ellipse(0, s*.28, s*.52, s*.42, 0, 0, Math.PI*2)
        ctx.fill()
        /* 4 dedos */
        const T = [
          {dx:-s*.44,dy:-s*.26,rx:s*.21,ry:s*.17,rot:-0.38},
          {dx:-s*.14,dy:-s*.50,rx:s*.19,ry:s*.16,rot:-0.10},
          {dx: s*.17,dy:-s*.50,rx:s*.19,ry:s*.16,rot: 0.10},
          {dx: s*.44,dy:-s*.26,rx:s*.21,ry:s*.17,rot: 0.38},
        ]
        T.forEach(t=>{
          ctx.beginPath()
          ctx.ellipse(t.dx, t.dy, t.rx, t.ry, t.rot, 0, Math.PI*2)
          ctx.fill()
        })
        ctx.restore()
      }

      class Paw {
        constructor(init=false){
          const c = PALETTE[Math.floor(Math.random()*PALETTE.length)]
          this.r = c[0]; this.g = c[1]; this.b = c[2]
          this.size  = 9 + Math.random()*20
          this.x     = Math.random()*W
          this.y     = init ? Math.random()*H : H+80
          this.vy    = -(0.12 + Math.random()*0.32)
          this.vx    = (Math.random()-.5)*0.22
          this.angle = Math.random()*Math.PI*2
          this.spin  = (Math.random()-.5)*0.005
          this.alpha = 0.18 + Math.random()*0.22
          this.mx=0; this.my=0
        }
        update(){
          const dx = this.x - mouse.x
          const dy = this.y - mouse.y
          const d  = Math.sqrt(dx*dx+dy*dy)
          const R  = 140
          if(d < R && d > 1){
            const f = (R-d)/R * 0.9
            this.mx += dx/d * f
            this.my += dy/d * f
          }
          this.mx *= 0.92; this.my *= 0.92
          this.x += this.vx + this.mx
          this.y += this.vy + this.my
          this.angle += this.spin
          if(this.y < -100){
            const c = PALETTE[Math.floor(Math.random()*PALETTE.length)]
            this.r=c[0]; this.g=c[1]; this.b=c[2]
            this.x = Math.random()*W
            this.y = H+80
            this.vy = -(0.12+Math.random()*0.32)
            this.vx = (Math.random()-.5)*0.22
            this.size = 9+Math.random()*20
            this.alpha = 0.18+Math.random()*0.22
          }
        }
        draw(){
          drawPaw(this.x, this.y, this.size, this.angle, this.r, this.g, this.b, this.alpha)
        }
      }

      const N = Math.min(55, Math.max(20, Math.floor(W*H/20000)))
      for(let i=0;i<N;i++) paws.push(new Paw(true))

      function loop(){
        ctx.clearRect(0,0,W,H)
        paws.forEach(p=>{p.update();p.draw()})
        requestAnimationFrame(loop)
      }
      loop()
    })()
    </script>
  </body>
</html>