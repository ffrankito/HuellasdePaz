---
// TODO: completar con nombres, precios y beneficios reales
// Ver landing/docs/entrevista-checklist.md
const planes = [
  {
    id: 'plan-1',
    nombre: 'Plan Básico', // TODO: nombre real
    precio: 'Consultar',
    descripcion: 'Descripción pendiente de confirmar con Huellas de Paz.',
    beneficios: ['Beneficio 1 (pendiente)', 'Beneficio 2 (pendiente)', 'Beneficio 3 (pendiente)'],
    destacado: false,
  },
  {
    id: 'plan-2',
    nombre: 'Plan Completo', // TODO: nombre real
    precio: 'Consultar',
    descripcion: 'Descripción pendiente de confirmar con Huellas de Paz.',
    beneficios: ['Beneficio 1 (pendiente)', 'Beneficio 2 (pendiente)', 'Beneficio 3 (pendiente)', 'Beneficio 4 (pendiente)'],
    destacado: true,
  },
  {
    id: 'plan-3',
    nombre: 'Plan Premium', // TODO: nombre real
    precio: 'Consultar',
    descripcion: 'Descripción pendiente de confirmar con Huellas de Paz.',
    beneficios: ['Beneficio 1 (pendiente)', 'Beneficio 2 (pendiente)', 'Beneficio 3 (pendiente)', 'Beneficio 4 (pendiente)', 'Beneficio 5 (pendiente)'],
    destacado: false,
  },
]

const WHATSAPP_NUMBER = '5493XXXXXXXXX' // TODO: reemplazar
---

<section id="planes" class="py-24 bg-stone-50">
  <div class="max-w-6xl mx-auto px-6">
    <div class="mb-14">
      <p class="text-brand-600 text-sm font-medium tracking-wide uppercase mb-3">Planes de previsión</p>
      <h2 class="font-display text-4xl font-semibold text-stone-900 mb-4">
        Planeá con anticipación, <br />sin preocupaciones
      </h2>
      <p class="text-stone-500 text-lg max-w-xl">
        Tomá la decisión hoy, cuando hay tiempo para pensar. Cuotas mensuales accesibles con cobertura creciente.
      </p>
    </div>

    <!-- Cobertura escalonada -->
    <div class="bg-white border border-stone-200 rounded-2xl p-6 mb-10 max-w-lg">
      <p class="text-sm font-medium text-stone-700 mb-4">Cobertura del plan</p>
      <div class="grid grid-cols-3 gap-4 text-center text-sm">
        <div class="bg-stone-50 rounded-xl p-4">
          <p class="text-2xl font-display font-semibold text-stone-400 mb-1">0%</p>
          <p class="text-stone-500 text-xs">Meses 1–6</p>
        </div>
        <div class="bg-brand-50 rounded-xl p-4">
          <p class="text-2xl font-display font-semibold text-brand-600 mb-1">50%</p>
          <p class="text-stone-500 text-xs">Meses 7–12</p>
        </div>
        <div class="bg-brand-600 rounded-xl p-4">
          <p class="text-2xl font-display font-semibold text-white mb-1">100%</p>
          <p class="text-brand-100 text-xs">Desde mes 13</p>
        </div>
      </div>
      <p class="text-xs text-stone-400 mt-3">* Mascota adicional: +50% sobre la cuota base.</p>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      {planes.map(plan => (
        <div class={`rounded-2xl border p-8 flex flex-col gap-6 bg-white ${plan.destacado ? 'border-brand-400 shadow-sm' : 'border-stone-200'}`}>
          {plan.destacado && <span class="inline-block self-start bg-brand-600 text-white text-xs font-medium px-3 py-1 rounded-full">Más completo</span>}
          <div>
            <h3 class="font-display text-xl font-semibold text-stone-900 mb-1">{plan.nombre}</h3>
            <p class="text-brand-600 text-2xl font-semibold mb-3">
              {plan.precio}<span class="text-stone-400 text-base font-normal">/mes</span>
            </p>
            <p class="text-stone-500 text-sm leading-relaxed">{plan.descripcion}</p>
          </div>
          <ul class="flex flex-col gap-2">
            {plan.beneficios.map(b => (
              <li class="flex items-center gap-2 text-sm text-stone-600">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="text-brand-600 flex-shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
                {b}
              </li>
            ))}
          </ul>
          <a
            href={`https://wa.me/${WHATSAPP_NUMBER}?text=Hola%2C%20quiero%20info%20sobre%20el%20${encodeURIComponent(plan.nombre)}`}
            target="_blank" rel="noopener noreferrer"
            class={`mt-auto inline-flex items-center justify-center px-5 py-2.5 rounded-full text-sm font-medium transition-colors ${plan.destacado ? 'bg-brand-600 hover:bg-brand-800 text-white' : 'border border-stone-300 hover:border-brand-600 text-stone-700 hover:text-brand-600'}`}
          >
            Consultar este plan
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
