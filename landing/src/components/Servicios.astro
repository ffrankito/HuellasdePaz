---
const servicios = [
  {
    id: 'cremacion-individual',
    titulo: 'Cremación individual',
    descripcion: 'Tu mascota es cremada sola, de manera privada. Recibís sus cenizas en una urna sellada con identificación, con la certeza absoluta de que son las de tu compañero.',
    detalle: ['Proceso individual y privado', 'Urna con identificación', 'Certificado de cremación', 'Entrega a domicilio opcional'],
    destacado: true,
    imagen: 'https://images.unsplash.com/photo-1592194996308-7b43878e84a6?w=600&q=80&fit=crop',
    emoji: '🕊️',
    alt: 'Gato naranja mirando a cámara',
  },
  {
    id: 'cremacion-comunitaria',
    titulo: 'Cremación comunitaria',
    descripcion: 'Una opción más accesible, con el mismo respeto y cuidado. Las cenizas se dispersan en el predio natural del cementerio parque.',
    detalle: ['Proceso grupal respetuoso', 'Dispersión en el predio', 'Certificado de servicio', 'Opción más accesible'],
    destacado: false,
    imagen: 'https://images.unsplash.com/photo-1543466835-00a7907e9de1?w=600&q=80&fit=crop',
    emoji: '🌿',
    alt: 'Perro feliz al aire libre',
  },
  {
    id: 'entierro',
    titulo: 'Entierro en parcela o nicho',
    descripcion: 'Un lugar físico donde ir a recordarlo. Parcelas y nichos en un espacio natural, tranquilo y cuidado, donde tu familia siempre puede visitarlo.',
    detalle: ['Parcela o nicho individual', 'Espacio natural y cuidado', 'Placa de identificación', 'Visitas libres'],
    destacado: false,
    imagen: 'https://images.unsplash.com/photo-1425082661705-1834bfd09dca?w=600&q=80&fit=crop',
    emoji: '🌸',
    alt: 'Conejo blanco en jardín',
  },
]
---

<section id="servicios" class="py-16 md:py-24 bg-servicios">
  <div class="max-w-6xl mx-auto px-5">

    <div class="mb-12 md:mb-16 max-w-xl">
      <p class="text-brand-600 text-xs md:text-sm font-medium tracking-widest uppercase mb-3">Servicios</p>
      <h2 class="font-display text-3xl md:text-4xl font-semibold text-stone-900 mb-4">
        Cada despedida <br />es única, como él
      </h2>
      <p class="text-stone-500 text-base md:text-lg leading-relaxed">
        Ya sea un perro, un gato, un conejo o cualquier compañero de vida —
        ofrecemos opciones para que puedas despedirte de la manera que sientas más adecuada.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
      {servicios.map(s => (
        <div class={`rounded-3xl overflow-hidden border flex flex-col ${s.destacado ? 'border-brand-300 shadow-md' : 'border-stone-200'}`}>

          <!-- Imagen -->
          <div class="relative h-48 md:h-52 overflow-hidden">
            <img
              src={s.imagen}
              alt={s.alt}
              class="w-full h-full object-cover transition-transform duration-500 hover:scale-105"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-stone-900/40 to-transparent"></div>
            {s.destacado && (
              <span class="absolute top-4 left-4 bg-brand-600 text-white text-xs font-medium px-3 py-1 rounded-full">
                Más elegido
              </span>
            )}
            <span class="absolute bottom-4 right-4 text-xl md:text-2xl">{s.emoji}</span>
          </div>

          <!-- Contenido -->
          <div class={`p-6 md:p-8 flex flex-col gap-4 md:gap-5 flex-1 ${s.destacado ? 'bg-brand-50' : 'bg-white'}`}>
            <div>
              <h3 class="font-display text-lg md:text-xl font-semibold text-stone-900 mb-2">{s.titulo}</h3>
              <p class="text-stone-600 text-sm leading-relaxed">{s.descripcion}</p>
            </div>
            <ul class="flex flex-col gap-2 mt-auto">
              {s.detalle.map(item => (
                <li class="flex items-center gap-2 text-sm text-stone-600">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="text-brand-600 flex-shrink-0">
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>

        </div>
      ))}
    </div>

    <!-- CTA inferior -->
    <div class="mt-12 md:mt-16 bg-stone-900 rounded-3xl p-8 md:p-10 flex flex-col md:flex-row items-center justify-between gap-5 md:gap-6 text-center md:text-left">
      <div>
        <h3 class="font-display text-xl md:text-2xl font-semibold text-white mb-2">
          ¿No sabés qué opción elegir?
        </h3>
        <p class="text-stone-400 text-sm max-w-md">
          Hablá con nosotros. Te acompañamos sin apuro a encontrar la despedida que más resuene con lo que vivieron juntos.
        </p>
      </div>
      <a
        href="#contacto"
        class="flex-shrink-0 inline-flex items-center justify-center gap-2 bg-brand-600 hover:bg-brand-800 text-white font-medium px-6 py-3.5 rounded-full transition-colors text-sm whitespace-nowrap w-full md:w-auto"
      >
        Hablar con un asesor
      </a>
    </div>

  </div>
</section>