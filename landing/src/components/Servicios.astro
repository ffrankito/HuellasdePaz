---
const servicios = [
  { id: 'cremacion-huellita',      titulo: 'Cremación Huellita',              precio: '$90.000',   descripcion: 'Una opción accesible, con el mismo respeto y cuidado de siempre. Ideal para quienes buscan un adiós digno sin la devolución de cenizas.', detalle: ['Atención 24/7','Retiro de mascota','Sin devolución de cenizas','Cremación comunitaria','Certificado de cremación'],                                                           destacado: false, pos: 'center 30%', imagen: 'https://images.unsplash.com/photo-1543466835-00a7907e9de1?w=600&q=80&fit=crop',      emoji: '🌿', alt: 'Perro feliz al aire libre' },
  { id: 'cremacion-companeros',    titulo: 'Cremación Compañeros',            precio: '$120.000',  descripcion: 'Tu mascota es cremada sola, de manera individual y privada. Recibís sus cenizas con la certeza absoluta de que son las de tu compañero.',   detalle: ['Atención 24/7','Retiro de mascota','Cremación individual','Entrega diferida entre 2 y 5 días hábiles en urna biodegradable','Certificado de cremación'], destacado: true,  pos: 'center 20%', imagen: 'https://images.unsplash.com/photo-1592194996308-7b43878e84a6?w=600&q=80&fit=crop',      emoji: '🕊️', alt: 'Gato naranja mirando a cámara' },
  { id: 'cremacion-siempre-juntos',titulo: 'Cremación Siempre Juntos',        precio: '$140.000',  descripcion: 'La opción más completa. Podés acompañar a tu mascota y recibir sus cenizas en el momento, sin esperas.',                                      detalle: ['Atención 24/7','Retiro de mascota','Cremación individual','Entrega de cenizas INMEDIATA','Acompañamiento presencial','Certificado de cremación'],          destacado: false, pos: 'center 40%', imagen: 'https://images.unsplash.com/photo-1587300003388-59208cc962cb?w=600&q=80&fit=crop',      emoji: '✨', alt: 'Golden retriever' },
  { id: 'jardin-del-recuerdo',     titulo: 'Inhumación Jardín del Recuerdo', precio: 'Consultar', descripcion: 'Una manera cálida y serena de despedir a tu mascota, permitiéndole descansar en un lugar de paz, rodeado de amor y recuerdo.',              detalle: ['Parcela individual en espacio natural','Lugar de paz para visitar cuando quieras','Mantenimiento anual incluido','Placa de identificación'],                destacado: false, pos: 'center 60%', imagen: 'https://images.unsplash.com/photo-1425082661705-1834bfd09dca?w=600&q=80&fit=crop',      emoji: '🌸', alt: 'Jardín de mascotas' },
]
---

<section id="servicios" class="py-16 md:py-24" style="position:relative;overflow:hidden">

  <!-- Orbes de luz flotantes — luz cálida y verde que se mueve despacio -->
  <div aria-hidden="true" style="position:absolute;inset:0;pointer-events:none;z-index:0">
    <div class="orb orb--verde"  style="width:700px;height:550px;top:-200px;right:-150px"></div>
    <div class="orb orb--calido" style="width:600px;height:450px;bottom:-150px;left:-100px"></div>
    <div class="orb orb--verde-2" style="width:400px;height:350px;top:40%;left:30%"></div>
  </div>

  <div style="position:relative;z-index:1;max-width:72rem;margin:0 auto;padding:0 1.25rem">

    <div class="mb-12 md:mb-16 max-w-xl reveal-item">
      <p class="text-brand-600 text-xs md:text-sm font-medium tracking-widest uppercase mb-3">Servicios</p>
      <h2 class="font-display text-3xl md:text-4xl font-semibold text-stone-900 mb-4">
        Cada despedida <br />es única, como él
      </h2>
      <p class="text-stone-500 text-base md:text-lg leading-relaxed">
        Ya sea un perro, un gato, un conejo o cualquier compañero de vida —
        ofrecemos opciones para que puedas despedirte de la manera que sientas más adecuada.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      {servicios.map((s, i) => (
        <div class={`servicio-card reveal-item rounded-3xl overflow-hidden border flex flex-col ${s.destacado ? 'border-brand-300 shadow-md' : 'border-stone-200'}`} style={`--reveal-delay:${i*0.14}s`}>
          <div class="servicio-img-wrap" style="position:relative;height:13rem;overflow:hidden">
            <img src={s.imagen} alt={s.alt} class="servicio-img" style={`width:100%;height:100%;object-fit:cover;object-position:${s.pos};transition:transform 0.6s ease`} loading="lazy" />
            <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,0.35),transparent)"></div>
            {s.destacado && <span style="position:absolute;top:14px;left:14px;background:#2d8a54;color:white;font-size:0.6875rem;font-weight:600;padding:4px 12px;border-radius:9999px;z-index:2">Más elegido</span>}
            <span class="servicio-emoji" style="position:absolute;bottom:14px;right:14px;font-size:1.4rem;z-index:2;transition:opacity 0.3s,transform 0.3s">{s.emoji}</span>
            <div class="servicio-overlay" style="position:absolute;bottom:0;left:0;right:0;z-index:3;background:linear-gradient(to top,rgba(8,30,18,0.97) 0%,rgba(8,30,18,0.8) 60%,transparent 100%);padding:20px 16px 16px;transform:translateY(100%);transition:transform 0.42s cubic-bezier(0.25,0.46,0.45,0.94)">
              <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:6px">
                {s.detalle.map(item => (
                  <li style="display:flex;align-items:flex-start;gap:7px;font-size:0.8125rem;color:rgba(255,255,255,0.88);line-height:1.4">
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#4db87a" stroke-width="2.5" style="flex-shrink:0;margin-top:2px"><polyline points="20 6 9 17 4 12"/></svg>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          </div>
          <div style={`padding:1.5rem 2rem;display:flex;flex-direction:column;gap:1rem;flex:1;background:${s.destacado ? '#f0faf4' : 'rgba(255,255,255,0.92)'};backdrop-filter:blur(4px)`}>
            <div>
              <h3 class="font-display" style="font-size:1.125rem;font-weight:600;color:#1c1917;margin:0 0 4px">{s.titulo}</h3>
              <p style="font-family:var(--font-display,'Playfair Display',serif);font-size:1.25rem;font-weight:700;color:#2d8a54;margin:0 0 8px">{s.precio}</p>
              <p style="font-size:0.875rem;color:#57534e;line-height:1.6;margin:0">{s.descripcion}</p>
            </div>
            <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:7px;margin-top:auto">
              {s.detalle.map(item => (
                <li style="display:flex;align-items:flex-start;gap:8px;font-size:0.875rem;color:#57534e">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#2d8a54" stroke-width="2.5" style="flex-shrink:0;margin-top:2px"><polyline points="20 6 9 17 4 12"/></svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>

    <!-- CTA premium -->
    <div class="cta-premium reveal-item">
      <div class="cta-bg" aria-hidden="true">
        <img src="https://images.unsplash.com/photo-1518717758536-85ae29035b6d?w=1400&q=80&fit=crop" alt="" loading="lazy" style="object-position:center 30%" />
        <div class="cta-overlay"></div>
      </div>
      <div class="cta-glow-border" aria-hidden="true"></div>
      <div class="cta-inner">
        <div class="cta-izq">
          <span class="cta-badge">
            <span class="cta-dot" aria-hidden="true"></span>
            Atención personalizada · 24hs
          </span>
          <h3 class="cta-titulo">¿No sabés qué<br/>opción elegir?</h3>
          <p class="cta-texto">Hablá con nosotros sin apuro. Te acompañamos a encontrar la despedida que más resuene con lo que vivieron juntos.</p>
          <div class="cta-pills">
            <span>Sin compromiso</span>
            <span>Respuesta rápida</span>
            <span>+20 años de experiencia</span>
          </div>
        </div>
        <div class="cta-der">
          <a href="#contacto" class="cta-btn-main">
            Hablar con un asesor
            <svg class="cta-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            <span class="cta-shimmer" aria-hidden="true"></span>
          </a>
          <a href="#contacto" class="cta-btn-sec">Dejá tus datos</a>
          <p class="cta-micro">Respondemos en menos de 2 horas</p>
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  @media(min-width:768px){ #servicios .cta-row{flex-direction:row;text-align:left} }

  .servicio-card { background:rgba(255,255,255,0.88); backdrop-filter:blur(6px); position:relative; transition:transform 0.3s,box-shadow 0.3s; }
  .servicio-card:hover { transform:translateY(-6px); box-shadow:0 0 0 1.5px #2d8a54, 0 8px 32px rgba(45,138,84,0.30), 0 20px 48px rgba(45,138,84,0.15); }

  /* Borde gradiente en hover — usa ::before con mask (compatible con overflow:hidden) */
  .servicio-card::before {
    content:""; position:absolute; inset:0; z-index:4; pointer-events:none;
    border-radius:inherit; padding:1.5px;
    background:linear-gradient(135deg,#aadfc2 0%,#2d8a54 55%,#1a5233 100%);
    -webkit-mask:linear-gradient(#fff 0 0) content-box,linear-gradient(#fff 0 0);
    -webkit-mask-composite:xor; mask-composite:exclude;
    opacity:0; transition:opacity 0.4s;
  }
  .servicio-card:hover::before { opacity:1; }
  .servicio-card:hover .servicio-img { transform:scale(1.07) !important; }
  .servicio-card:hover .servicio-overlay { transform:translateY(0) !important; }
  .servicio-card:hover .servicio-emoji { opacity:0 !important; transform:scale(0.5) !important; }

  .reveal-item { opacity:0; transform:translateY(28px); transition:opacity 0.55s ease calc(var(--reveal-delay,0s)),transform 0.55s ease calc(var(--reveal-delay,0s)); }
  .reveal-item.is-visible { opacity:1; transform:translateY(0); }

  .btn-light-border { position:relative; display:inline-flex; align-items:center; justify-content:center; padding:13px 28px; border-radius:9999px; text-decoration:none; font-size:0.9375rem; font-weight:500; color:white; border:1px solid rgba(255,255,255,0.15); transition:background-color 0.25s; overflow:hidden; isolation:isolate; white-space:nowrap; min-width:180px; }
  .btn-light-border:hover { background-color:rgba(45,138,84,0.2); }
  .btn-light-border__light { position:absolute; inset:-2px; border-radius:inherit; background:conic-gradient(from var(--la,0deg),transparent 0deg,transparent 60deg,rgba(77,184,122,0.9) 90deg,rgba(255,255,255,0.7) 120deg,rgba(77,184,122,0.9) 150deg,transparent 180deg,transparent 360deg); animation:la-run 2.8s linear infinite; z-index:-1; -webkit-mask:linear-gradient(#fff 0 0) content-box,linear-gradient(#fff 0 0); -webkit-mask-composite:xor; mask-composite:exclude; padding:2px; }
  @property --la { syntax:'<angle>'; initial-value:0deg; inherits:false; }
  @keyframes la-run { to{--la:360deg} }

  .cta-premium { position:relative; border-radius:20px; overflow:hidden; margin-top:3rem; min-height:180px; display:flex; align-items:stretch; }
  .cta-bg { position:absolute; inset:0; z-index:0; }
  .cta-bg img { width:100%; height:100%; object-fit:cover; object-position:center 35%; }
  .cta-overlay { position:absolute; inset:0; background:linear-gradient(110deg,rgba(6,20,12,0.97) 0%,rgba(8,30,18,0.94) 50%,rgba(15,55,30,0.78) 80%,rgba(20,65,38,0.60) 100%); }
  .cta-glow-border { position:absolute; inset:-2px; border-radius:22px; background:conic-gradient(from var(--ga,0deg),transparent 0deg,transparent 75deg,rgba(77,184,122,0.85) 105deg,rgba(200,255,220,0.55) 135deg,rgba(77,184,122,0.85) 165deg,transparent 195deg,transparent 360deg); -webkit-mask:linear-gradient(#fff 0 0) content-box,linear-gradient(#fff 0 0); -webkit-mask-composite:xor; mask-composite:exclude; padding:2px; animation:ga-spin 4.5s linear infinite; z-index:0; pointer-events:none; }
  @property --ga { syntax:'<angle>'; initial-value:0deg; inherits:false; }
  @keyframes ga-spin { to { --ga:360deg; } }
  .cta-inner { position:relative; z-index:1; display:flex; flex-direction:column; gap:2rem; padding:2.5rem 2.25rem; width:100%; align-items:flex-start; }
  @media(min-width:768px){ .cta-inner{flex-direction:row;align-items:center;justify-content:space-between;padding:2.25rem 3rem} }
  .cta-izq { flex:1; max-width:500px; }
  .cta-badge { display:inline-flex; align-items:center; gap:7px; background:rgba(77,184,122,0.14); border:1px solid rgba(77,184,122,0.28); color:#9dd9b8; font-size:11px; font-weight:500; padding:4px 12px; border-radius:99px; letter-spacing:0.05em; margin-bottom:14px; }
  .cta-dot { width:6px; height:6px; border-radius:50%; background:#4db87a; flex-shrink:0; animation:dot-blink 1.8s ease-in-out infinite; }
  @keyframes dot-blink { 0%,100%{opacity:1} 50%{opacity:0.25} }
  .cta-titulo { font-family:var(--font-display,'Playfair Display',serif); font-size:clamp(1.4rem,2.6vw,1.875rem); font-weight:600; color:white; line-height:1.2; margin:0 0 10px; }
  .cta-texto { font-size:0.9rem; color:rgba(255,255,255,0.62); line-height:1.65; margin:0 0 16px; max-width:380px; }
  .cta-pills { display:flex; flex-wrap:wrap; gap:7px; }
  .cta-pills span { font-size:11px; color:rgba(255,255,255,0.4); border:1px solid rgba(255,255,255,0.12); padding:3px 10px; border-radius:99px; }
  .cta-der { display:flex; flex-direction:column; align-items:flex-start; gap:10px; flex-shrink:0; }
  @media(min-width:768px){ .cta-der{align-items:flex-end} }
  .cta-btn-main { position:relative; display:inline-flex; align-items:center; gap:8px; background:#2d8a54; color:white; font-size:0.9375rem; font-weight:600; padding:14px 28px; border-radius:99px; text-decoration:none; overflow:hidden; white-space:nowrap; transition:background 0.2s,transform 0.2s; animation:cta-pulse 2.5s ease-out infinite; }
  .cta-btn-main:hover { background:#1a5233; transform:translateY(-2px); animation-play-state:paused; }
  .cta-arrow { transition:transform 0.2s; }
  .cta-btn-main:hover .cta-arrow { transform:translateX(3px); }
  .cta-shimmer { position:absolute; top:0; left:-100%; width:55%; height:100%; background:linear-gradient(120deg,transparent 20%,rgba(255,255,255,0.25) 50%,transparent 80%); transition:left 0.55s; pointer-events:none; }
  .cta-btn-main:hover .cta-shimmer { left:140%; }
  @keyframes cta-pulse { 0%{box-shadow:0 4px 20px rgba(45,138,84,0.4),0 0 0 0 rgba(45,138,84,0.5)} 70%{box-shadow:0 4px 20px rgba(45,138,84,0.4),0 0 0 13px rgba(45,138,84,0)} 100%{box-shadow:0 4px 20px rgba(45,138,84,0.4),0 0 0 0 rgba(45,138,84,0)} }
  .cta-btn-sec { display:inline-flex; align-items:center; gap:6px; color:rgba(255,255,255,0.6); font-size:0.8125rem; font-weight:500; text-decoration:none; padding:9px 18px; border-radius:99px; border:1px solid rgba(255,255,255,0.16); transition:all 0.2s; }
  .cta-btn-sec:hover { color:white; border-color:rgba(255,255,255,0.38); background:rgba(255,255,255,0.05); }
  .cta-micro { font-size:11px; color:rgba(255,255,255,0.3); margin:0; }
  @media(min-width:768px){ .cta-micro{text-align:right} }
  @media(prefers-reduced-motion:reduce){ .reveal-item{opacity:1;transform:none;transition:none} .servicio-card{transition:none} .btn-light-border__light,.cta-glow-border{animation:none;opacity:0.3} .cta-btn-main,.cta-dot{animation:none} }
</style>

<script>
  const obs = new IntersectionObserver(es => es.forEach(e => { if(e.isIntersecting){e.target.classList.add('is-visible');obs.unobserve(e.target)} }), {threshold:0.1})
  document.querySelectorAll('#servicios .reveal-item').forEach(el => obs.observe(el))
</script>