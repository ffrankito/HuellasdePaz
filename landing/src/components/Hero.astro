---
const WHATSAPP_NUMBER = '5493XXXXXXXXX' // TODO: reemplazar con número real
const WHATSAPP_URL = `https://wa.me/${WHATSAPP_NUMBER}?text=Hola%2C%20quiero%20consultar%20sobre%20Huellas%20de%20Paz`
---

<section class="min-h-screen flex items-center pt-16 bg-stone-50">
  <div class="max-w-6xl mx-auto px-6 py-24 grid md:grid-cols-2 gap-16 items-center">

    <div>
      <p class="text-brand-600 text-sm font-medium tracking-wide uppercase mb-4">
        Rosario · Habilitación formal
      </p>
      <h1 class="font-display text-5xl md:text-6xl font-semibold text-stone-900 leading-tight mb-6">
        Un último adiós <br />
        <span class="text-brand-600">con dignidad</span>
      </h1>
      <p class="text-stone-600 text-lg leading-relaxed mb-8 max-w-md">
        Acompañamos a las familias en uno de los momentos más difíciles.
        Cremación individual, comunitaria y cementerio parque para mascotas
        en Rosario, con más de 20 años de trayectoria.
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a href={WHATSAPP_URL} target="_blank" rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2 bg-brand-600 hover:bg-brand-800 text-white font-medium px-6 py-3 rounded-full transition-colors">
          Consultar por WhatsApp
        </a>
        <a href="#planes"
          class="inline-flex items-center justify-center gap-2 border border-stone-300 hover:border-brand-600 text-stone-700 hover:text-brand-600 font-medium px-6 py-3 rounded-full transition-colors">
          Ver planes de previsión
        </a>
      </div>
      <div class="mt-10 flex flex-col sm:flex-row gap-4 text-sm text-stone-500">
        <div class="flex items-center gap-2">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-brand-600">
            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
          </svg>
          Primer crematorio habilitado en Rosario
        </div>
        <div class="flex items-center gap-2">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-brand-600">
            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
          </svg>
          +20 años de trayectoria
        </div>
      </div>
    </div>

    <!-- TODO: reemplazar con foto real -->
    <div class="hidden md:block">
      <div class="aspect-square rounded-3xl bg-stone-100 border border-stone-200 flex items-center justify-center">
        <div class="text-center text-stone-400">
          <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" class="mx-auto mb-3">
            <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/>
          </svg>
          <p class="text-sm">Foto del crematorio<br/>(pendiente)</p>
        </div>
      </div>
    </div>

  </div>
</section>
