---
const WHATSAPP_NUMBER = '5493XXXXXXXXX'
const WHATSAPP_URL = `https://wa.me/${WHATSAPP_NUMBER}?text=Hola%2C%20quiero%20consultar%20sobre%20Huellas%20de%20Paz`

const fotos = [
  { src: 'https://images.unsplash.com/photo-1450778869180-41d0601e046e?w=1600&q=80&fit=crop', alt: 'Perro y gato juntos', pos: 'center 40%' },
  { src: 'https://images.unsplash.com/photo-1587300003388-59208cc962cb?w=1600&q=80&fit=crop', alt: 'Golden retriever', pos: 'center 35%' },
  { src: 'https://images.unsplash.com/photo-1514888286974-6c03e2ca1dba?w=1600&q=80&fit=crop', alt: 'Gato naranja', pos: 'center 30%' },
  { src: 'https://images.unsplash.com/photo-1425082661705-1834bfd09dca?w=1600&q=80&fit=crop', alt: 'Conejo blanco', pos: 'center 50%' },
  { src: 'https://images.unsplash.com/photo-1552053831-71594a27632d?w=1600&q=80&fit=crop', alt: 'Cachorro golden', pos: 'center 40%' },
  { src: 'https://images.unsplash.com/photo-1548199973-03cce0bbc87b?w=1600&q=80&fit=crop', alt: 'Dos perros juntos', pos: 'center 35%' },
  { src: '/hero/hero-1.png', alt: 'Mascotas juntas', pos: 'center 50%' },
  { src: '/hero/hero-2.png', alt: 'Perro husky', pos: 'center 40%' },
  { src: '/hero/hero-3.png', alt: 'Hamster', pos: 'center 50%' },
  { src: '/hero/hero-4.png', alt: 'Gato naranja de cerca', pos: 'center 45%' },
]
---

<section class="relative min-h-screen flex items-center pt-16 overflow-hidden">

  <!-- Slideshow de fondo -->
  <div class="absolute inset-0 z-0">
    {fotos.map((foto, i) => (
      <img
        src={foto.src}
        alt={foto.alt}
        class="hero-slide"
        style={`opacity:${i === 0 ? 1 : 0};object-position:${foto.pos}`}
        loading={i === 0 ? 'eager' : 'lazy'}
      />
    ))}
    <div class="absolute inset-0 bg-gradient-to-r from-stone-900/85 via-stone-900/60 to-stone-900/20"></div>
  </div>

  <!-- Huellas flotantes -->
  <div class="paws-container" aria-hidden="true">
    <span class="paw paw-1"><svg viewBox="0 0 40 40" fill="currentColor"><ellipse cx="20" cy="26" rx="9" ry="7"/><ellipse cx="10" cy="17" rx="4" ry="3.5" transform="rotate(-15 10 17)"/><ellipse cx="17" cy="13" rx="3.5" ry="3" transform="rotate(-5 17 13)"/><ellipse cx="24" cy="13" rx="3.5" ry="3" transform="rotate(5 24 13)"/><ellipse cx="30" cy="17" rx="4" ry="3.5" transform="rotate(15 30 17)"/></svg></span>
    <span class="paw paw-2"><svg viewBox="0 0 40 40" fill="currentColor"><ellipse cx="20" cy="26" rx="9" ry="7"/><ellipse cx="10" cy="17" rx="4" ry="3.5" transform="rotate(-15 10 17)"/><ellipse cx="17" cy="13" rx="3.5" ry="3" transform="rotate(-5 17 13)"/><ellipse cx="24" cy="13" rx="3.5" ry="3" transform="rotate(5 24 13)"/><ellipse cx="30" cy="17" rx="4" ry="3.5" transform="rotate(15 30 17)"/></svg></span>
    <span class="paw paw-3"><svg viewBox="0 0 40 40" fill="currentColor"><ellipse cx="20" cy="26" rx="9" ry="7"/><ellipse cx="10" cy="17" rx="4" ry="3.5" transform="rotate(-15 10 17)"/><ellipse cx="17" cy="13" rx="3.5" ry="3" transform="rotate(-5 17 13)"/><ellipse cx="24" cy="13" rx="3.5" ry="3" transform="rotate(5 24 13)"/><ellipse cx="30" cy="17" rx="4" ry="3.5" transform="rotate(15 30 17)"/></svg></span>
    <span class="paw paw-4"><svg viewBox="0 0 40 40" fill="currentColor"><ellipse cx="20" cy="26" rx="9" ry="7"/><ellipse cx="10" cy="17" rx="4" ry="3.5" transform="rotate(-15 10 17)"/><ellipse cx="17" cy="13" rx="3.5" ry="3" transform="rotate(-5 17 13)"/><ellipse cx="24" cy="13" rx="3.5" ry="3" transform="rotate(5 24 13)"/><ellipse cx="30" cy="17" rx="4" ry="3.5" transform="rotate(15 30 17)"/></svg></span>
    <span class="paw paw-5"><svg viewBox="0 0 40 40" fill="currentColor"><ellipse cx="20" cy="26" rx="9" ry="7"/><ellipse cx="10" cy="17" rx="4" ry="3.5" transform="rotate(-15 10 17)"/><ellipse cx="17" cy="13" rx="3.5" ry="3" transform="rotate(-5 17 13)"/><ellipse cx="24" cy="13" rx="3.5" ry="3" transform="rotate(5 24 13)"/><ellipse cx="30" cy="17" rx="4" ry="3.5" transform="rotate(15 30 17)"/></svg></span>
    <span class="paw paw-6"><svg viewBox="0 0 40 40" fill="currentColor"><ellipse cx="20" cy="26" rx="9" ry="7"/><ellipse cx="10" cy="17" rx="4" ry="3.5" transform="rotate(-15 10 17)"/><ellipse cx="17" cy="13" rx="3.5" ry="3" transform="rotate(-5 17 13)"/><ellipse cx="24" cy="13" rx="3.5" ry="3" transform="rotate(5 24 13)"/><ellipse cx="30" cy="17" rx="4" ry="3.5" transform="rotate(15 30 17)"/></svg></span>
    <span class="paw paw-7"><svg viewBox="0 0 40 40" fill="currentColor"><ellipse cx="20" cy="26" rx="9" ry="7"/><ellipse cx="10" cy="17" rx="4" ry="3.5" transform="rotate(-15 10 17)"/><ellipse cx="17" cy="13" rx="3.5" ry="3" transform="rotate(-5 17 13)"/><ellipse cx="24" cy="13" rx="3.5" ry="3" transform="rotate(5 24 13)"/><ellipse cx="30" cy="17" rx="4" ry="3.5" transform="rotate(15 30 17)"/></svg></span>
  </div>

  <!-- Contenido -->
  <div class="relative z-10 max-w-6xl mx-auto px-5 py-20 md:py-24">
    <div class="max-w-xl">
      <p class="text-brand-300 text-xs md:text-sm font-medium tracking-widest uppercase mb-4 md:mb-5">
        Rosario · Habilitación formal · +20 años
      </p>
      <h1 class="font-display text-4xl md:text-6xl font-semibold text-white leading-tight mb-5 md:mb-6">
        El último regalo <br />
        <span class="text-brand-300">que podés darle</span>
      </h1>
      <p class="text-stone-200 text-base md:text-lg leading-relaxed mb-8 md:mb-10 max-w-md">
        Tu compañero de vida merece una despedida digna y llena de amor.
        Acompañamos a las familias de Rosario hace más de 20 años,
        con el primer crematorio de mascotas con habilitación formal de la ciudad.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 md:gap-4">
        <a href={WHATSAPP_URL} target="_blank" rel="noopener noreferrer" class="btn-wa">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
            <path d="M12 0C5.373 0 0 5.373 0 12c0 2.123.553 4.116 1.522 5.847L.057 23.852a.5.5 0 0 0 .611.61l6.074-1.47A11.95 11.95 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.9a9.9 9.9 0 0 1-5.031-1.372l-.36-.214-3.733.904.936-3.633-.234-.373A9.862 9.862 0 0 1 2.1 12C2.1 6.534 6.534 2.1 12 2.1c5.466 0 9.9 4.434 9.9 9.9 0 5.466-4.434 9.9-9.9 9.9z"/>
          </svg>
          Consultar por WhatsApp
        </a>
        <a href="#planes" class="inline-flex items-center justify-center gap-2 border border-white/30 hover:border-white/60 text-white font-medium px-6 py-3.5 rounded-full transition-colors text-sm backdrop-blur-sm">
          Ver planes de previsión
        </a>
      </div>

      <div class="mt-10 md:mt-12 flex flex-wrap gap-4 md:gap-6">
        <div class="trust-badge trust-badge--1">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-brand-300 flex-shrink-0"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          Primer crematorio habilitado en Rosario
        </div>
        <div class="trust-badge trust-badge--2">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-brand-300 flex-shrink-0"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
          +20 años acompañando familias
        </div>
        <div class="trust-badge trust-badge--3">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-brand-300 flex-shrink-0"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          Atención las 24 horas
        </div>
      </div>
    </div>
  </div>

  <!-- Ola SVG al final — transición suave al blanco -->
  <div class="wave-bottom" aria-hidden="true">
    <svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M0,40 C240,80 480,0 720,40 C960,80 1200,0 1440,40 L1440,80 L0,80 Z" fill="white"/>
    </svg>
  </div>

</section>

<!-- Franja de confianza con contadores animados -->
<div class="bg-white border-b border-stone-100 py-6 md:py-8">
  <div class="max-w-6xl mx-auto px-5">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-8 text-center">
      <div>
        <p class="font-display text-2xl md:text-3xl font-semibold text-brand-600 mb-1">
          <span class="counter" data-target="20" data-prefix="+">0</span>
        </p>
        <p class="text-stone-500 text-xs md:text-sm">Años de experiencia</p>
      </div>
      <div>
        <p class="font-display text-2xl md:text-3xl font-semibold text-brand-600 mb-1">
          <span class="counter" data-target="100" data-suffix="%">0</span>
        </p>
        <p class="text-stone-500 text-xs md:text-sm">Habilitación formal</p>
      </div>
      <div>
        <p class="font-display text-2xl md:text-3xl font-semibold text-brand-600 mb-1">
          <span class="counter" data-target="24" data-suffix="hs">0</span>
        </p>
        <p class="text-stone-500 text-xs md:text-sm">Disponibilidad</p>
      </div>
      <div>
        <p class="font-display text-2xl md:text-3xl font-semibold text-brand-600 mb-1">❤️</p>
        <p class="text-stone-500 text-xs md:text-sm">Trato con amor</p>
      </div>
    </div>
  </div>
</div>

<style>
  /* ── SLIDESHOW ── */
  .hero-slide {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transition: opacity 1.5s ease-in-out;
  }

  /* ── HUELLAS FLOTANTES ── */
  .paws-container { position: absolute; inset: 0; z-index: 1; overflow: hidden; pointer-events: none; }
  .paw { position: absolute; color: white; opacity: 0; animation: paw-float linear infinite; }
  .paw svg { display: block; }
  .paw-1 { left: 8%;  width: 22px; animation-duration: 18s; animation-delay: 0s;   bottom: -40px; --r: 0deg; }
  .paw-2 { left: 20%; width: 16px; animation-duration: 22s; animation-delay: 3s;   bottom: -40px; --r: 20deg; }
  .paw-3 { left: 35%; width: 28px; animation-duration: 16s; animation-delay: 7s;   bottom: -40px; --r: -10deg; }
  .paw-4 { left: 55%; width: 18px; animation-duration: 24s; animation-delay: 1.5s; bottom: -40px; --r: 15deg; }
  .paw-5 { left: 68%; width: 24px; animation-duration: 19s; animation-delay: 5s;   bottom: -40px; --r: -5deg; }
  .paw-6 { left: 80%; width: 14px; animation-duration: 21s; animation-delay: 9s;   bottom: -40px; --r: -20deg; }
  .paw-7 { left: 92%; width: 20px; animation-duration: 17s; animation-delay: 12s;  bottom: -40px; --r: 10deg; }
  @keyframes paw-float {
    0%   { transform: translateY(0) rotate(var(--r, 0deg)) scale(0.8); opacity: 0; }
    8%   { opacity: 0.12; }
    60%  { opacity: 0.08; }
    90%  { opacity: 0.03; }
    100% { transform: translateY(-110vh) rotate(calc(var(--r, 0deg) + 30deg)) scale(1.1); opacity: 0; }
  }

  /* ── OLA SVG al final del hero ── */
  .wave-bottom {
    position: absolute;
    bottom: -2px;
    left: 0;
    right: 0;
    z-index: 2;
    line-height: 0;
  }
  .wave-bottom svg {
    display: block;
    width: 100%;
    height: 60px;
  }

  /* ── BOTÓN WHATSAPP ── */
  .btn-wa {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    background-color: #25D366;
    color: white;
    font-size: 0.875rem;
    font-weight: 500;
    padding: 14px 24px;
    border-radius: 9999px;
    text-decoration: none;
    overflow: hidden;
    transition: background-color 0.25s ease, transform 0.2s ease;
    animation: wa-pulse 2.5s ease-out infinite;
  }
  .btn-wa::before {
    content: '';
    position: absolute;
    top: 0; left: -100%;
    width: 60%; height: 100%;
    background: linear-gradient(120deg, transparent 20%, rgba(255,255,255,0.35) 50%, transparent 80%);
    transition: left 0.5s ease;
    pointer-events: none;
  }
  .btn-wa:hover { background-color: #128C7E; transform: translateY(-2px); animation-play-state: paused; }
  .btn-wa:hover::before { left: 140%; }
  .btn-wa:active { transform: translateY(0); }
  @keyframes wa-pulse {
    0%   { box-shadow: 0 0 0 0 rgba(37,211,102,0.55); }
    70%  { box-shadow: 0 0 0 12px rgba(37,211,102,0); }
    100% { box-shadow: 0 0 0 0 rgba(37,211,102,0); }
  }

  /* ── TRUST BADGES ── */
  .trust-badge { display: flex; align-items: center; gap: 8px; color: rgb(231 229 228); font-size: 0.8125rem; opacity: 0; transform: translateY(10px); animation: badge-in 0.5s ease forwards; }
  .trust-badge--1 { animation-delay: 0.3s; }
  .trust-badge--2 { animation-delay: 0.5s; }
  .trust-badge--3 { animation-delay: 0.7s; }
  @keyframes badge-in { to { opacity: 1; transform: translateY(0); } }

  @media (prefers-reduced-motion: reduce) {
    .paw { animation: none; opacity: 0; }
    .trust-badge { animation: none; opacity: 1; transform: none; }
    .btn-wa { animation: none; }
  }
</style>

<script>
  /* Slideshow */
  const slides = document.querySelectorAll('.hero-slide') as NodeListOf<HTMLElement>
  let current = 0
  if (slides.length > 1) {
    setInterval(() => {
      slides[current].style.opacity = '0'
      current = (current + 1) % slides.length
      slides[current].style.opacity = '1'
    }, 5000)
  }

  /* Contadores animados — arrancan cuando entran al viewport */
  const counters = document.querySelectorAll('.counter')
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return
      const el = entry.target as HTMLElement
      const target = parseInt(el.dataset.target || '0')
      const prefix = el.dataset.prefix || ''
      const suffix = el.dataset.suffix || ''
      const duration = 1800
      const start = performance.now()
      const update = (now: number) => {
        const elapsed = now - start
        const progress = Math.min(elapsed / duration, 1)
        const eased = 1 - Math.pow(1 - progress, 3)
        el.textContent = prefix + Math.round(eased * target) + suffix
        if (progress < 1) requestAnimationFrame(update)
      }
      requestAnimationFrame(update)
      observer.unobserve(el)
    })
  }, { threshold: 0.5 })
  counters.forEach(c => observer.observe(c))
</script>