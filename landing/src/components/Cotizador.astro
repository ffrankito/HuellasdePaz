---
// TODO: reemplazar con URL real cuando el cotizador esté deployado
const COTIZADOR_URL = 'https://cotizador.huellasdepaz.com.ar'
---

<section id="cotizador" class="py-24 bg-brand-800">
  <div class="max-w-6xl mx-auto px-6 text-center">
    <p class="text-brand-200 text-sm font-medium tracking-wide uppercase mb-4">Cotizador online</p>
    <h2 class="font-display text-4xl font-semibold text-white mb-4">
      Calculá el costo <br />en minutos
    </h2>
    <p class="text-brand-200 text-lg max-w-lg mx-auto mb-10">
      Seleccioná el servicio, el tamaño de tu mascota y los adicionales. Precio al instante, sin compromiso.
    </p>
    <a href={COTIZADOR_URL} target="_blank" rel="noopener noreferrer"
      class="inline-flex items-center gap-2 bg-white hover:bg-stone-50 text-brand-800 font-semibold px-8 py-4 rounded-full transition-colors text-lg">
      Ir al cotizador
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
      </svg>
    </a>
  </div>
</section>
