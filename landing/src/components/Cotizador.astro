---
const COTIZADOR_URL = 'https://cotizador.huellasdepaz.com.ar'
---

<section id="cotizador" class="relative py-20 md:py-28 overflow-hidden">

  <!-- Foto de fondo -->
  <div class="absolute inset-0 z-0">
    <img
      src="https://images.unsplash.com/photo-1548199973-03cce0bbc87b?w=1600&q=80&fit=crop"
      alt="Dos perros corriendo juntos"
      class="w-full h-full object-cover object-center"
      loading="lazy"
    />

  </div>

    <div class="absolute inset-0" style="background: rgba(0,0,0,0.55);"></div>

  <!-- Animalitos decorativos flotando -->
  <div class="absolute inset-0 z-0 pointer-events-none select-none overflow-hidden">
    <span class="absolute text-5xl opacity-10" style="top: 8%; left: 4%;">🐶</span>
    <span class="absolute text-4xl opacity-10" style="top: 15%; right: 6%;">🐱</span>
    <span class="absolute text-3xl opacity-10" style="top: 55%; left: 2%;">🐰</span>
    <span class="absolute text-4xl opacity-10" style="bottom: 12%; left: 8%;">🐾</span>
    <span class="absolute text-5xl opacity-10" style="bottom: 8%; right: 4%;">🐕</span>
    <span class="absolute text-3xl opacity-10" style="top: 40%; right: 3%;">🐈</span>
    <span class="absolute text-2xl opacity-10" style="top: 70%; right: 10%;">🐾</span>
    <span class="absolute text-3xl opacity-10" style="top: 25%; left: 12%;">🐹</span>
    <span class="absolute text-2xl opacity-10" style="bottom: 30%; left: 18%;">🦜</span>
    <span class="absolute text-3xl opacity-10" style="bottom: 20%; right: 15%;">🐇</span>
  </div>

  <!-- Contenido -->
  <div class="relative z-10 max-w-6xl mx-auto px-5">
    <div class="max-w-3xl mx-auto text-center">

      <p class="text-brand-300 text-xs md:text-sm font-medium tracking-widest uppercase mb-4">
        Cotizador online
      </p>
      <h2 class="font-display text-3xl md:text-5xl font-semibold text-white mb-5 leading-tight">
        Conocé el costo <br />
        <span class="text-brand-300">en pocos minutos</span>
      </h2>
      <p class="text-stone-300 text-base md:text-lg max-w-lg mx-auto mb-10 leading-relaxed">
        Seleccioná el tipo de mascota, el servicio y los adicionales.
        Precio al instante, sin compromiso, sin registrarte.
      </p>

      <!-- Features -->
      <div class="flex flex-wrap justify-center gap-4 md:gap-6 mb-10">
        <div class="flex items-center gap-2 text-stone-300 text-sm">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-brand-400 flex-shrink-0">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
          Sin registrarte
        </div>
        <div class="flex items-center gap-2 text-stone-300 text-sm">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-brand-400 flex-shrink-0">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
          Resultado inmediato
        </div>
        <div class="flex items-center gap-2 text-stone-300 text-sm">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-brand-400 flex-shrink-0">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
          Todas las mascotas
        </div>
        <div class="flex items-center gap-2 text-stone-300 text-sm">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-brand-400 flex-shrink-0">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
          Sin compromiso
        </div>
      </div>

      <a
        href={COTIZADOR_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-3 bg-white hover:bg-stone-50 text-brand-800 font-semibold px-8 py-4 rounded-full transition-all text-base md:text-lg shadow-lg hover:shadow-xl hover:-translate-y-0.5"
      >
        <span>🐾</span>
        Ir al cotizador
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
        </svg>
      </a>

      <p class="text-stone-500 text-xs mt-4">
        También podés consultar directamente por WhatsApp
      </p>

    </div>
  </div>

</section>