---
const COTIZADOR_URL = '/cotizador'
---

<section id="cotizador" class="cotizador-section relative py-20 md:py-28 overflow-hidden">

  <!-- Foto de fondo -->
  <div class="absolute inset-0 z-0">
    <img
      src="https://images.unsplash.com/photo-1548199973-03cce0bbc87b?w=1600&q=80&fit=crop"
      alt="Dos perros corriendo juntos"
      class="w-full h-full object-cover object-center"
      style="filter:brightness(1.1) saturate(1.05)"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-overlay"></div>
  </div>

  <!-- Contenido -->
  <div class="relative z-10 max-w-6xl mx-auto px-5">
    <div class="max-w-3xl mx-auto text-center">
      <p style="color:rgba(255,255,255,0.65); font-size:0.75rem; font-weight:500; letter-spacing:0.15em; text-transform:uppercase; margin-bottom:1rem">
        Cotizador online
      </p>
      <h2 class="font-display text-3xl md:text-5xl font-semibold text-white mb-5 leading-tight">
        Conocé el costo <br />
        <span class="text-brand-300">en pocos minutos</span>
      </h2>
      <p class="text-white/80 text-base md:text-lg max-w-lg mx-auto mb-10 leading-relaxed">
        Seleccioná el tipo de mascota, el servicio y los adicionales.
        Precio al instante, sin compromiso, sin registrarte.
      </p>
      <div class="flex flex-wrap justify-center gap-4 md:gap-6 mb-10">
        {['Sin registrarte','Resultado inmediato','Todas las mascotas','Sin compromiso'].map(f => (
          <div class="flex items-center gap-2 text-white/75 text-sm">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="text-brand-300 flex-shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
            {f}
          </div>
        ))}
      </div>
      <a href={COTIZADOR_URL} target="_blank" rel="noopener noreferrer" class="btn-cotizador">
        <span style="font-size:18px">🐾</span>
        Ir al cotizador
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        <span class="btn-shimmer" aria-hidden="true"></span>
      </a>
      <p class="text-white/40 text-xs mt-4">También podés consultar directamente por WhatsApp al 341 752-3248</p>
    </div>
  </div>

</section>

<style>
  .bg-overlay {
    background: linear-gradient(
      to bottom,
      rgba(10,30,35,0.55) 0%,
      rgba(10,30,35,0.45) 50%,
      rgba(10,30,35,0.55) 100%
    );
  }

  .btn-cotizador {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background-color: white;
    color: #126070;
    font-size: 1rem;
    font-weight: 600;
    padding: 16px 32px;
    border-radius: 9999px;
    text-decoration: none;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0,0,0,0.2);
    transition: background-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
  }
  .btn-cotizador:hover { background-color: #f0f8fa; box-shadow: 0 8px 32px rgba(0,0,0,0.25); transform: translateY(-2px); }
  .btn-cotizador:active { transform: translateY(0); }
  .btn-shimmer { position: absolute; top: 0; left: -100%; width: 55%; height: 100%; background: linear-gradient(120deg, transparent 20%, rgba(26,138,156,0.15) 50%, transparent 80%); transition: left 0.6s ease; pointer-events: none; }
  .btn-cotizador:hover .btn-shimmer { left: 150%; }
</style>
