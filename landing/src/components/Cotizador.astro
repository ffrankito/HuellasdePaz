---
const COTIZADOR_URL = 'https://cotizador.huellasdepaz.com.ar'

/* Estrellas: posición, tamaño, duración del twinkle, delay */
const stars = [
  {l:'3%',  t:'8%',  s:2, dur:2.1, d:0   },
  {l:'8%',  t:'22%', s:1, dur:3.4, d:0.5 },
  {l:'14%', t:'55%', s:3, dur:1.8, d:1.2 },
  {l:'19%', t:'12%', s:1, dur:4.1, d:0.3 },
  {l:'24%', t:'72%', s:2, dur:2.8, d:1.8 },
  {l:'29%', t:'38%', s:1, dur:3.2, d:0.7 },
  {l:'34%', t:'85%', s:2, dur:2.5, d:2.1 },
  {l:'40%', t:'18%', s:3, dur:1.9, d:0.9 },
  {l:'45%', t:'62%', s:1, dur:3.7, d:1.5 },
  {l:'50%', t:'32%', s:2, dur:2.3, d:0.2 },
  {l:'55%', t:'78%', s:1, dur:4.0, d:1.1 },
  {l:'60%', t:'9%',  s:3, dur:2.0, d:2.4 },
  {l:'65%', t:'48%', s:2, dur:3.1, d:0.6 },
  {l:'70%', t:'25%', s:1, dur:2.7, d:1.7 },
  {l:'75%', t:'68%', s:3, dur:1.7, d:0.4 },
  {l:'80%', t:'15%', s:2, dur:3.8, d:1.9 },
  {l:'84%', t:'82%', s:1, dur:2.4, d:0.8 },
  {l:'89%', t:'42%', s:2, dur:3.3, d:1.3 },
  {l:'93%', t:'6%',  s:3, dur:2.2, d:2.0 },
  {l:'97%', t:'58%', s:1, dur:3.6, d:0.1 },
  {l:'6%',  t:'91%', s:2, dur:2.9, d:1.4 },
  {l:'22%', t:'3%',  s:1, dur:4.2, d:1.6 },
  {l:'47%', t:'94%', s:2, dur:2.6, d:0.0 },
  {l:'72%', t:'95%', s:1, dur:3.5, d:2.2 },
  {l:'88%', t:'89%', s:3, dur:2.1, d:0.5 },
]

/* Estrellas fugaces */
const shoots = [
  {t:'15%', dur:6,  d:0  },
  {t:'35%', dur:9,  d:3  },
  {t:'55%', dur:12, d:7  },
  {t:'70%', dur:8,  d:14 },
]
---

<section id="cotizador" class="cotizador-section relative py-20 md:py-28 overflow-hidden">

  <!-- Foto de fondo -->
  <div class="absolute inset-0 z-0">
    <img
      src="https://images.unsplash.com/photo-1548199973-03cce0bbc87b?w=1600&q=80&fit=crop"
      alt="Dos perros corriendo juntos"
      class="w-full h-full object-cover object-center"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-overlay"></div>
  </div>

  <!-- Estrellas — cada mascota es una estrella -->
  <div class="stars-layer" aria-hidden="true">
    {stars.map(s => (
      <span
        class="star"
        style={`left:${s.l};top:${s.t};width:${s.s}px;height:${s.s}px;animation-duration:${s.dur}s;animation-delay:${s.d}s`}
      ></span>
    ))}
    {/* Estrellas fugaces */}
    {shoots.map(sh => (
      <span
        class="shooting-star"
        style={`top:${sh.t};width:120px;animation-duration:${sh.dur}s;animation-delay:${sh.d}s`}
      ></span>
    ))}
  </div>

  <!-- Contenido -->
  <div class="relative z-10 max-w-6xl mx-auto px-5">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-brand-300 text-xs md:text-sm font-medium tracking-widest uppercase mb-4">
        Cotizador online
      </p>
      <h2 class="font-display text-3xl md:text-5xl font-semibold text-white mb-5 leading-tight">
        Conocé el costo <br />
        <span class="text-brand-300">en pocos minutos</span>
      </h2>
      <p class="text-stone-300 text-base md:text-lg max-w-lg mx-auto mb-10 leading-relaxed">
        Seleccioná el tipo de mascota, el servicio y los adicionales.
        Precio al instante, sin compromiso, sin registrarte.
      </p>
      <div class="flex flex-wrap justify-center gap-4 md:gap-6 mb-10">
        {['Sin registrarte','Resultado inmediato','Todas las mascotas','Sin compromiso'].map(f => (
          <div class="flex items-center gap-2 text-stone-300 text-sm">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-brand-400 flex-shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
            {f}
          </div>
        ))}
      </div>
      <a href={COTIZADOR_URL} target="_blank" rel="noopener noreferrer" class="btn-cotizador">
        <span style="font-size:18px">🐾</span>
        Ir al cotizador
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        <span class="btn-shimmer" aria-hidden="true"></span>
      </a>
      <p class="text-stone-500 text-xs mt-4">También podés consultar directamente por WhatsApp</p>
    </div>
  </div>

</section>

<style>
  /* ── OVERLAY oscuro sobre la foto ── */
  .bg-overlay {
    background: linear-gradient(
      to bottom,
      rgba(5,15,10,0.75) 0%,
      rgba(5,20,12,0.65) 50%,
      rgba(5,15,10,0.75) 100%
    );
  }

  /* ── ESTRELLAS — cada mascota es una estrella ── */
  .stars-layer {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
    overflow: hidden;
  }

  .star {
    position: absolute;
    border-radius: 50%;
    background: white;
    animation: star-twinkle ease-in-out infinite;
  }

  @keyframes star-twinkle {
    0%, 100% { opacity: 0.08; transform: scale(1); }
    50%       { opacity: 0.95; transform: scale(1.6); }
  }

  /* Estrellas fugaces — aparecen cada tanto */
  .shooting-star {
    position: absolute;
    left: -150px;
    height: 1.5px;
    background: linear-gradient(to right, transparent, rgba(255,255,255,0.7), transparent);
    border-radius: 999px;
    animation: shoot linear infinite;
    opacity: 0;
  }

  @keyframes shoot {
    0%   { transform: translateX(-150px) translateY(0) rotate(-20deg); opacity: 0; }
    3%   { opacity: 0.8; }
    20%  { opacity: 0; }
    100% { transform: translateX(120vw) translateY(160px) rotate(-20deg); opacity: 0; }
  }

  /* ── BOTÓN ── */
  .btn-cotizador {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background-color: white;
    color: #1a5233;
    font-size: 1rem;
    font-weight: 600;
    padding: 16px 32px;
    border-radius: 9999px;
    text-decoration: none;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0,0,0,0.2);
    transition: background-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
  }
  .btn-cotizador:hover { background-color: #f0faf4; box-shadow: 0 8px 32px rgba(0,0,0,0.25); transform: translateY(-2px); }
  .btn-cotizador:active { transform: translateY(0); }
  .btn-shimmer { position: absolute; top: 0; left: -100%; width: 55%; height: 100%; background: linear-gradient(120deg, transparent 20%, rgba(45,138,84,0.15) 50%, transparent 80%); transition: left 0.6s ease; pointer-events: none; }
  .btn-cotizador:hover .btn-shimmer { left: 150%; }

  @media (prefers-reduced-motion: reduce) {
    .star { animation: none; opacity: 0.25; }
    .shooting-star { display: none; }
    .btn-cotizador { transition: none; }
  }
</style>