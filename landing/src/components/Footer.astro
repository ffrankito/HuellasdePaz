---
const WHATSAPP_NUMBER = '5493XXXXXXXXX' // TODO: reemplazar
const WHATSAPP_URL = `https://wa.me/${WHATSAPP_NUMBER}`
const year = new Date().getFullYear()
---

<footer class="bg-stone-900 text-stone-400 py-16">
  <div class="max-w-6xl mx-auto px-6">
    <div class="grid md:grid-cols-4 gap-12 mb-12">

      <!-- Marca -->
      <div class="md:col-span-2">
        <p class="font-display text-white text-xl font-semibold mb-3">🐾 Huellas de Paz</p>
        <p class="text-sm leading-relaxed text-stone-500 max-w-sm">
          El primer crematorio de mascotas con habilitación formal en Rosario.
          Más de 20 años acompañando a las familias en uno de los momentos más difíciles.
        </p>
        <a
          href={WHATSAPP_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 mt-5 bg-brand-600 hover:bg-brand-800 text-white text-sm font-medium px-5 py-2.5 rounded-full transition-colors"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
            <path d="M12 0C5.373 0 0 5.373 0 12c0 2.123.553 4.116 1.522 5.847L.057 23.852a.5.5 0 0 0 .611.61l6.074-1.47A11.95 11.95 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.9a9.9 9.9 0 0 1-5.031-1.372l-.36-.214-3.733.904.936-3.633-.234-.373A9.862 9.862 0 0 1 2.1 12C2.1 6.534 6.534 2.1 12 2.1c5.466 0 9.9 4.434 9.9 9.9 0 5.466-4.434 9.9-9.9 9.9z"/>
          </svg>
          Escribinos por WhatsApp
        </a>
      </div>

      <!-- Servicios -->
      <div>
        <p class="text-white text-sm font-medium mb-4">Servicios</p>
        <ul class="flex flex-col gap-2 text-sm">
          <li><a href="#servicios" class="hover:text-white transition-colors">Cremación individual</a></li>
          <li><a href="#servicios" class="hover:text-white transition-colors">Cremación comunitaria</a></li>
          <li><a href="#servicios" class="hover:text-white transition-colors">Entierro en parcela</a></li>
          <li><a href="#planes" class="hover:text-white transition-colors">Planes de previsión</a></li>
          <li><a href="#cotizador" class="hover:text-white transition-colors">Cotizador online</a></li>
        </ul>
      </div>

      <!-- Contacto -->
      <div>
        <p class="text-white text-sm font-medium mb-4">Contacto</p>
        <ul class="flex flex-col gap-3 text-sm">
          <li class="flex items-start gap-2">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="mt-0.5 flex-shrink-0 text-stone-500">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
            </svg>
            <span class="text-stone-500">Rosario, Santa Fe<br/><span class="text-stone-600 text-xs">Dirección — disponible en julio 2025</span></span>
          </li>
          <li class="flex items-center gap-2">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="flex-shrink-0 text-stone-500">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13.6 19.79 19.79 0 0 1 1.61 5a2 2 0 0 1 1.99-2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 10.91a16 16 0 0 0 6 6l1.27-.85a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 18.35z"/>
            </svg>
            <span class="text-stone-500">Teléfono — disponible pronto</span>
          </li>
          <li>
            <a href={WHATSAPP_URL} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 hover:text-white transition-colors">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" class="flex-shrink-0 text-green-500">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
                <path d="M12 0C5.373 0 0 5.373 0 12c0 2.123.553 4.116 1.522 5.847L.057 23.852a.5.5 0 0 0 .611.61l6.074-1.47A11.95 11.95 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.9a9.9 9.9 0 0 1-5.031-1.372l-.36-.214-3.733.904.936-3.633-.234-.373A9.862 9.862 0 0 1 2.1 12C2.1 6.534 6.534 2.1 12 2.1c5.466 0 9.9 4.434 9.9 9.9 0 5.466-4.434 9.9-9.9 9.9z"/>
              </svg>
              WhatsApp disponible 24hs
            </a>
          </li>
        </ul>
      </div>

    </div>

    <div class="border-t border-stone-800 pt-8 flex flex-col md:flex-row items-center justify-between gap-4 text-xs text-stone-600">
      <p>© {year} Huellas de Paz. Todos los derechos reservados.</p>
      <p>Desarrollado por <span class="text-stone-500">Ravenna</span></p>
    </div>
  </div>
</footer>