---
const CRM_URL = 'https://huellasde-paz.vercel.app'
---

<section id="memoriales" class="mem-section">

  <div class="mem-inner">

    <!-- Header -->
    <div class="mem-header reveal-m">
      <p class="mem-eyebrow">Memoriales</p>
      <h2 class="font-display mem-title">Un lugar para recordarlos</h2>
      <p class="mem-subtitle">
        Con permiso de sus familias, compartimos estos recuerdos.<br/>
        Cada uno vivió una historia única e irrepetible.
      </p>
    </div>

    <!-- Skeleton -->
    <div id="memSkeleton" class="mem-grid">
      {Array.from({length: 3}).map(() => (
        <div class="mem-sk-wrap">
          <div class="mem-sk-card">
            <div class="mem-sk-shimmer"></div>
          </div>
        </div>
      ))}
    </div>

    <!-- Grid dinámico -->
    <div id="memGrid" class="mem-grid" style="display:none"></div>

    <!-- Empty state -->
    <div id="memEmpty" class="mem-empty" style="display:none">
      <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
        <circle cx="24" cy="24" r="23" stroke="#d6d3d1" stroke-width="1.5"/>
        <path d="M24 34c-5 0-9-3.6-9-8s4-8 9-8 9 3.6 9 8-4 8-9 8z" fill="#e7e5e4"/>
        <circle cx="18" cy="20" r="3" fill="#e7e5e4"/>
        <circle cx="30" cy="20" r="3" fill="#e7e5e4"/>
        <circle cx="24" cy="16" r="2.5" fill="#e7e5e4"/>
      </svg>
      <p class="mem-empty-text">Los memoriales aparecerán aquí cuando las familias los activen.</p>
    </div>

    <!-- CTA bottom -->
    <div id="memCta" class="mem-cta" style="display:none">
      <a href={`${CRM_URL}/memorial`} target="_blank" rel="noopener noreferrer" class="mem-cta-link">
        Ver todos los memoriales
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12"/>
          <polyline points="12 5 19 12 12 19"/>
        </svg>
      </a>
    </div>

  </div>
</section>

<script define:vars={{ CRM_URL }}>
  const TRACKERS = Array.from({length: 25}, (_, i) =>
    `<div class="tracker tr-${i+1}"></div>`
  ).join('')

  function buildCard(m) {
    const extracto = m.dedicatoria
      ? (m.dedicatoria.length > 90 ? m.dedicatoria.slice(0, 90).trimEnd() + '…' : m.dedicatoria)
      : null
    const emoji = m.especie === 'perro' ? '🐕' : m.especie === 'gato' ? '🐈' : '🐾'
    const especieStr = [
      m.especie ? m.especie.charAt(0).toUpperCase() + m.especie.slice(1) : null,
      m.raza || null
    ].filter(Boolean).join(' · ')

    const wrap = document.createElement('div')
    wrap.className = 'mem-wrap noselect reveal-m'

    const canvas = document.createElement('div')
    canvas.className = 'mem-canvas'
    canvas.innerHTML = TRACKERS  // estático, sin datos del API

    const card = document.createElement('div')
    card.className = 'mem-card'

    if (m.foto && typeof m.foto === 'string' && m.foto.startsWith('https://')) {
      const img = document.createElement('img')
      img.className = 'mem-photo'
      img.src = m.foto
      img.setAttribute('alt', m.nombre ? String(m.nombre).slice(0, 200) : '')
      img.loading = 'lazy'
      card.appendChild(img)
    } else {
      const fallback = document.createElement('div')
      fallback.className = 'mem-fallback'
      fallback.textContent = emoji
      card.appendChild(fallback)
    }

    const overlay = document.createElement('div')
    overlay.className = 'mem-overlay'
    card.appendChild(overlay)

    const textDiv = document.createElement('div')
    textDiv.className = 'mem-text'

    if (especieStr) {
      const p = document.createElement('p')
      p.className = 'mem-especie'
      p.textContent = especieStr
      textDiv.appendChild(p)
    }

    const h3 = document.createElement('h3')
    h3.className = 'font-display mem-nombre'
    h3.textContent = m.nombre || ''
    textDiv.appendChild(h3)

    if (extracto) {
      const p = document.createElement('p')
      p.className = 'mem-ded'
      p.textContent = '“' + extracto + '”'
      textDiv.appendChild(p)
    }

    card.appendChild(textDiv)
    canvas.appendChild(card)
    wrap.appendChild(canvas)
    return wrap
  }

  async function loadMemoriales() {
    const skeleton = document.getElementById('memSkeleton')
    const grid = document.getElementById('memGrid')
    const empty = document.getElementById('memEmpty')
    const cta = document.getElementById('memCta')

    try {
      const res = await fetch(`${CRM_URL}/api/memorial/publicos`)
      const data = await res.json()
      skeleton.style.display = 'none'

      if (!Array.isArray(data) || !data.length) {
        empty.style.display = 'flex'
        return
      }

      grid.style.display = ''
      data.slice(0, 6).forEach(m => grid.appendChild(buildCard(m)))

      if (data.length > 6) cta.style.display = 'flex'

      const obs = new IntersectionObserver(entries => {
        entries.forEach(e => {
          if (e.isIntersecting) { e.target.classList.add('is-visible'); obs.unobserve(e.target) }
        })
      }, { threshold: 0.06 })
      grid.querySelectorAll('.reveal-m').forEach(el => obs.observe(el))

    } catch {
      skeleton.style.display = 'none'
      empty.style.display = 'flex'
    }
  }

  loadMemoriales()

  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('is-visible'); obs.unobserve(e.target) } })
  }, { threshold: 0.1 })
  document.querySelectorAll('#memoriales .reveal-m').forEach(el => obs.observe(el))
</script>

<style is:global>
  /* ── Section ── */
  .mem-section {
    padding: 5rem 0 6rem;
    background: #faf9f7;
    position: relative;
  }
  .mem-section::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(to right, transparent, #e7e5e4 30%, #e7e5e4 70%, transparent);
  }
  .mem-inner {
    max-width: 72rem;
    margin: 0 auto;
    padding: 0 1.25rem;
  }

  /* ── Header ── */
  .mem-header { text-align: center; margin-bottom: 3.5rem; }
  .mem-eyebrow {
    color: #2d8a54; font-size: 0.7rem; font-weight: 600;
    letter-spacing: 0.14em; text-transform: uppercase; margin: 0 0 14px;
  }
  .mem-title {
    font-size: clamp(1.75rem, 4vw, 2.5rem); font-weight: 600;
    color: #1c1917; line-height: 1.2; margin: 0 0 16px; letter-spacing: -0.02em;
  }
  .mem-subtitle {
    font-size: 1rem; color: #78716c; line-height: 1.75; margin: 0 auto; max-width: 28rem;
  }

  /* ── Grid ── */
  .mem-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  /* ── Skeleton ── */
  .mem-sk-wrap { aspect-ratio: 3/4; }
  .mem-sk-card {
    width: 100%; height: 100%;
    border-radius: 20px; overflow: hidden;
  }
  .mem-sk-shimmer {
    width: 100%; height: 100%;
    background: linear-gradient(90deg, #e7e5e4 25%, #d6d3d1 50%, #e7e5e4 75%);
    background-size: 200% 100%;
    animation: sk-shimmer 1.6s infinite;
  }
  @keyframes sk-shimmer {
    0%   { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }

  /* ── Card wrapper (the <a>) ── */
  .mem-wrap {
    display: block;
    text-decoration: none;
    aspect-ratio: 3/4;
    position: relative;
    transition: 200ms;
  }
  .mem-wrap:active { transform: scale(0.97); }

  /* ── Canvas — 5×5 hover grid ── */
  .mem-canvas {
    perspective: 800px;
    position: absolute;
    inset: 0;
    z-index: 10;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    grid-template-rows: repeat(5, 1fr);
    grid-template-areas:
      "tr-1  tr-2  tr-3  tr-4  tr-5"
      "tr-6  tr-7  tr-8  tr-9  tr-10"
      "tr-11 tr-12 tr-13 tr-14 tr-15"
      "tr-16 tr-17 tr-18 tr-19 tr-20"
      "tr-21 tr-22 tr-23 tr-24 tr-25";
  }

  /* ── Trackers ── */
  .tracker { z-index: 200; }
  .tr-1  { grid-area: tr-1;  }
  .tr-2  { grid-area: tr-2;  }
  .tr-3  { grid-area: tr-3;  }
  .tr-4  { grid-area: tr-4;  }
  .tr-5  { grid-area: tr-5;  }
  .tr-6  { grid-area: tr-6;  }
  .tr-7  { grid-area: tr-7;  }
  .tr-8  { grid-area: tr-8;  }
  .tr-9  { grid-area: tr-9;  }
  .tr-10 { grid-area: tr-10; }
  .tr-11 { grid-area: tr-11; }
  .tr-12 { grid-area: tr-12; }
  .tr-13 { grid-area: tr-13; }
  .tr-14 { grid-area: tr-14; }
  .tr-15 { grid-area: tr-15; }
  .tr-16 { grid-area: tr-16; }
  .tr-17 { grid-area: tr-17; }
  .tr-18 { grid-area: tr-18; }
  .tr-19 { grid-area: tr-19; }
  .tr-20 { grid-area: tr-20; }
  .tr-21 { grid-area: tr-21; }
  .tr-22 { grid-area: tr-22; }
  .tr-23 { grid-area: tr-23; }
  .tr-24 { grid-area: tr-24; }
  .tr-25 { grid-area: tr-25; }

  /* ── Card ── */
  .mem-card {
    position: absolute;
    inset: 0;
    z-index: 0;
    border-radius: 20px;
    overflow: hidden;
    transition: 700ms;
    box-shadow: 0 4px 24px rgba(0,0,0,0.12);
  }
  .mem-card::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    border-radius: 20px;
    background: linear-gradient(145deg, rgba(45,138,84,0.55) 0%, rgba(28,25,23,0.7) 100%);
    filter: blur(28px);
    opacity: 25%;
    transition: 200ms;
    transform: translateY(8px) scale(0.96);
  }
  .mem-wrap:hover .mem-card::before {
    opacity: 70%;
    transform: translateY(12px) scale(0.94);
  }

  .mem-photo {
    position: absolute;
    inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
    transition: filter 0.4s ease;
    filter: brightness(0.9);
  }
  .tracker:hover ~ .mem-card .mem-photo {
    filter: brightness(0.78);
  }

  .mem-fallback {
    position: absolute;
    inset: 0;
    display: flex; align-items: center; justify-content: center;
    font-size: 4rem;
    background: linear-gradient(145deg, #2a2420, #1a2a1e);
  }

  .mem-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0,0,0,0.82) 0%,
      rgba(0,0,0,0.28) 45%,
      rgba(0,0,0,0.04) 70%,
      transparent 100%
    );
  }

  .mem-text {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    padding: 1.375rem;
    z-index: 2;
  }
  .mem-especie {
    font-size: 0.68rem; font-weight: 500;
    color: rgba(255,255,255,0.52);
    letter-spacing: 0.08em; text-transform: uppercase;
    margin: 0 0 5px;
  }
  .mem-nombre {
    font-size: 1.375rem; font-weight: 600;
    color: white; margin: 0 0 6px;
    line-height: 1.2; letter-spacing: -0.01em;
    text-shadow: 0 2px 10px rgba(0,0,0,0.4);
  }
  .mem-ded {
    font-size: 0.8rem;
    color: rgba(255,255,255,0.68);
    line-height: 1.6; margin: 0;
    font-style: italic;
    font-family: Georgia, 'Times New Roman', serif;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ── Tracker hover → tilt ── */
  .tracker:hover ~ .mem-card { transition: 300ms; filter: brightness(1.05); }

  .tr-1:hover  ~ .mem-card { transition: 125ms ease-in-out; transform: rotateX(20deg) rotateY(-10deg); }
  .tr-2:hover  ~ .mem-card { transition: 125ms ease-in-out; transform: rotateX(20deg) rotateY(-5deg);  }
  .tr-3:hover  ~ .mem-card { transition: 125ms ease-in-out; transform: rotateX(20deg) rotateY(0deg);   }
  .tr-4:hover  ~ .mem-card { transition: 125ms ease-in-out; transform: rotateX(20deg) rotateY(5deg);   }
  .tr-5:hover  ~ .mem-card { transition: 125ms ease-in-out; transform: rotateX(20deg) rotateY(10deg);  }
  .tr-6:hover  ~ .mem-card { transition: 125ms ease-in-out; transform: rotateX(10deg) rotateY(-10deg); }
  .tr-7:hover  ~ .mem-card { transition: 125ms ease-in-out; transform: rotateX(10deg) rotateY(-5deg);  }
  .tr-8:hover  ~ .mem-card { transition: 125ms ease-in-out; transform: rotateX(10deg) rotateY(0deg);   }
  .tr-9:hover  ~ .mem-card { transition: 125ms ease-in-out; transform: rotateX(10deg) rotateY(5deg);   }
  .tr-10:hover ~ .mem-card { transition: 125ms ease-in-out; transform: rotateX(10deg) rotateY(10deg);  }
  .tr-11:hover ~ .mem-card { transition: 125ms ease-in-out; transform: rotateX(0deg)  rotateY(-10deg); }
  .tr-12:hover ~ .mem-card { transition: 125ms ease-in-out; transform: rotateX(0deg)  rotateY(-5deg);  }
  .tr-13:hover ~ .mem-card { transition: 125ms ease-in-out; transform: rotateX(0deg)  rotateY(0deg);   }
  .tr-14:hover ~ .mem-card { transition: 125ms ease-in-out; transform: rotateX(0deg)  rotateY(5deg);   }
  .tr-15:hover ~ .mem-card { transition: 125ms ease-in-out; transform: rotateX(0deg)  rotateY(10deg);  }
  .tr-16:hover ~ .mem-card { transition: 125ms ease-in-out; transform: rotateX(-10deg) rotateY(-10deg);}
  .tr-17:hover ~ .mem-card { transition: 125ms ease-in-out; transform: rotateX(-10deg) rotateY(-5deg); }
  .tr-18:hover ~ .mem-card { transition: 125ms ease-in-out; transform: rotateX(-10deg) rotateY(0deg);  }
  .tr-19:hover ~ .mem-card { transition: 125ms ease-in-out; transform: rotateX(-10deg) rotateY(5deg);  }
  .tr-20:hover ~ .mem-card { transition: 125ms ease-in-out; transform: rotateX(-10deg) rotateY(10deg); }
  .tr-21:hover ~ .mem-card { transition: 125ms ease-in-out; transform: rotateX(-20deg) rotateY(-10deg);}
  .tr-22:hover ~ .mem-card { transition: 125ms ease-in-out; transform: rotateX(-20deg) rotateY(-5deg); }
  .tr-23:hover ~ .mem-card { transition: 125ms ease-in-out; transform: rotateX(-20deg) rotateY(0deg);  }
  .tr-24:hover ~ .mem-card { transition: 125ms ease-in-out; transform: rotateX(-20deg) rotateY(5deg);  }
  .tr-25:hover ~ .mem-card { transition: 125ms ease-in-out; transform: rotateX(-20deg) rotateY(10deg); }

  /* ── Empty ── */
  .mem-empty {
    flex-direction: column; align-items: center; gap: 14px;
    padding: 80px 24px; text-align: center;
  }
  .mem-empty-text { color: #a8a29e; font-size: 0.9375rem; margin: 0; max-width: 320px; line-height: 1.6; }

  /* ── CTA ── */
  .mem-cta { justify-content: center; margin-top: 2.5rem; }
  .mem-cta-link {
    display: inline-flex; align-items: center; gap: 8px;
    font-size: 0.875rem; font-weight: 600; color: #2d8a54;
    text-decoration: none; padding: 12px 28px;
    border: 1.5px solid #2d8a54; border-radius: 99px;
    transition: background 0.2s ease, color 0.2s ease, gap 0.2s ease;
  }
  .mem-cta-link:hover { background: #2d8a54; color: white; gap: 12px; }

  /* ── Reveal ── */
  .reveal-m { opacity: 0; transform: translateY(20px); transition: opacity 0.55s ease, transform 0.55s ease; }
  .reveal-m.is-visible { opacity: 1; transform: translateY(0); }

  /* ── noselect ── */
  .noselect { -webkit-user-select: none; user-select: none; }

  /* ── Responsive ── */
  @media (max-width: 860px) {
    .mem-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 520px) {
    .mem-grid { grid-template-columns: repeat(2, 1fr); gap: 0.75rem; }
    .mem-nombre { font-size: 1.1rem; }
    .mem-ded { display: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .reveal-m { opacity: 1; transform: none; transition: none; }
    .tr-1:hover ~ .mem-card,  .tr-2:hover ~ .mem-card,  .tr-3:hover ~ .mem-card,
    .tr-4:hover ~ .mem-card,  .tr-5:hover ~ .mem-card,  .tr-6:hover ~ .mem-card,
    .tr-7:hover ~ .mem-card,  .tr-8:hover ~ .mem-card,  .tr-9:hover ~ .mem-card,
    .tr-10:hover ~ .mem-card, .tr-11:hover ~ .mem-card, .tr-12:hover ~ .mem-card,
    .tr-13:hover ~ .mem-card, .tr-14:hover ~ .mem-card, .tr-15:hover ~ .mem-card,
    .tr-16:hover ~ .mem-card, .tr-17:hover ~ .mem-card, .tr-18:hover ~ .mem-card,
    .tr-19:hover ~ .mem-card, .tr-20:hover ~ .mem-card, .tr-21:hover ~ .mem-card,
    .tr-22:hover ~ .mem-card, .tr-23:hover ~ .mem-card, .tr-24:hover ~ .mem-card,
    .tr-25:hover ~ .mem-card { transform: none; transition: none; }
  }
</style>
