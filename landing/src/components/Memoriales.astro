---
const CRM_URL = 'https://huellasde-paz.vercel.app'
---

<section id="memoriales" class="mem-section">

  <div class="mem-inner">

    <!-- Header -->
    <div class="mem-header reveal-m">
      <p class="mem-eyebrow">Memoriales</p>
      <h2 class="font-display mem-title">Un lugar para recordarlos</h2>
      <p class="mem-subtitle">
        Con permiso de sus familias, compartimos estos recuerdos.<br>
        Cada uno vivió una historia única e irrepetible.
      </p>
    </div>

    <!-- Skeleton -->
    <div id="memSkeleton" class="mem-grid">
      {Array.from({length: 3}).map((_, i) => (
        <div class:list={['mem-sk-card', i === 0 ? 'mem-sk-featured' : '']}>
          <div class="mem-sk-img"></div>
        </div>
      ))}
    </div>

    <!-- Grid dinámico -->
    <div id="memGrid" class="mem-grid" style="display:none"></div>

    <!-- Empty state -->
    <div id="memEmpty" class="mem-empty" style="display:none">
      <svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="24" cy="24" r="23" stroke="#d6d3d1" stroke-width="1.5"/>
        <path d="M24 34c-5 0-9-3.6-9-8s4-8 9-8 9 3.6 9 8-4 8-9 8z" fill="#e7e5e4"/>
        <circle cx="18" cy="20" r="3" fill="#e7e5e4"/>
        <circle cx="30" cy="20" r="3" fill="#e7e5e4"/>
        <circle cx="24" cy="16" r="2.5" fill="#e7e5e4"/>
      </svg>
      <p class="mem-empty-text">Los memoriales aparecerán aquí cuando las familias los activen.</p>
    </div>

    <!-- CTA bottom -->
    <div id="memCta" class="mem-cta" style="display:none">
      <a href={`${CRM_URL}/memorial`} target="_blank" rel="noopener noreferrer" class="mem-cta-link">
        Ver todos los memoriales
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
    </div>

  </div>
</section>

<script define:vars={{ CRM_URL }}>
  function fmtFecha(f) {
    if (!f) return null
    try {
      return new Date(f).toLocaleDateString('es-AR', { day: 'numeric', month: 'long', year: 'numeric' })
    } catch { return null }
  }

  function buildCard(m, featured) {
    const url = `${CRM_URL}/memorial/${m.id}`
    const fallacimiento = fmtFecha(m.fechaFallecimiento)
    const nacimiento = fmtFecha(m.fechaNacimiento)
    const extracto = m.dedicatoria
      ? (m.dedicatoria.length > 120 ? m.dedicatoria.slice(0, 120).trimEnd() + '…' : m.dedicatoria)
      : null

    const card = document.createElement('a')
    card.href = url
    card.target = '_blank'
    card.rel = 'noopener noreferrer'
    card.className = 'mem-card reveal-m' + (featured ? ' mem-card--featured' : '')

    card.innerHTML = `
      <div class="mem-card-img">
        ${m.foto
          ? `<img src="${m.foto}" alt="${m.nombre}" loading="lazy" />`
          : `<div class="mem-card-fallback">
              <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.5)" stroke-width="1.2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
             </div>`
        }
        <div class="mem-card-overlay"></div>
        <div class="mem-card-content">
          <div class="mem-card-top">
            ${nacimiento && fallacimiento ? `<p class="mem-card-years">${nacimiento.split(' ').pop()} — ${fallacimiento.split(' ').pop()}</p>` : fallacimiento ? `<p class="mem-card-years">† ${fallacimiento}</p>` : ''}
          </div>
          <div class="mem-card-bottom">
            <h3 class="font-display mem-card-name">${m.nombre}</h3>
            ${m.especie ? `<p class="mem-card-especie">${m.especie.charAt(0).toUpperCase() + m.especie.slice(1)}</p>` : ''}
            ${extracto ? `<p class="mem-card-ded">"${extracto}"</p>` : ''}
            <span class="mem-card-cta">
              Ver memorial
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </span>
          </div>
        </div>
      </div>
    `
    return card
  }

  async function loadMemoriales() {
    const skeleton = document.getElementById('memSkeleton')
    const grid = document.getElementById('memGrid')
    const empty = document.getElementById('memEmpty')
    const cta = document.getElementById('memCta')

    try {
      const res = await fetch(`${CRM_URL}/api/memorial/publicos`)
      const data = await res.json()

      skeleton.style.display = 'none'

      if (!Array.isArray(data) || !data.length) {
        empty.style.display = 'flex'
        return
      }

      grid.style.display = ''
      data.slice(0, 7).forEach((m, i) => grid.appendChild(buildCard(m, i === 0)))

      if (data.length > 4) cta.style.display = 'flex'

      const obs = new IntersectionObserver(entries => {
        entries.forEach(e => {
          if (e.isIntersecting) { e.target.classList.add('is-visible'); obs.unobserve(e.target) }
        })
      }, { threshold: 0.06 })
      grid.querySelectorAll('.reveal-m').forEach(el => obs.observe(el))

    } catch {
      skeleton.style.display = 'none'
      empty.style.display = 'flex'
    }
  }

  loadMemoriales()

  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('is-visible'); obs.unobserve(e.target) } })
  }, { threshold: 0.1 })
  document.querySelectorAll('#memoriales .reveal-m').forEach(el => obs.observe(el))
</script>

<style>
  /* ── Section ── */
  .mem-section {
    padding: 5rem 0 6rem;
    background: #faf9f7;
    position: relative;
  }
  .mem-section::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(to right, transparent, #e7e5e4 30%, #e7e5e4 70%, transparent);
  }

  .mem-inner {
    max-width: 72rem;
    margin: 0 auto;
    padding: 0 1.25rem;
  }

  /* ── Header ── */
  .mem-header {
    text-align: center;
    margin-bottom: 3.5rem;
  }
  .mem-eyebrow {
    color: #2d8a54;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin: 0 0 14px;
  }
  .mem-title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 600;
    color: #1c1917;
    line-height: 1.2;
    margin: 0 0 16px;
    letter-spacing: -0.02em;
  }
  .mem-subtitle {
    font-size: 1rem;
    color: #78716c;
    line-height: 1.75;
    margin: 0;
    max-width: 28rem;
    margin-left: auto;
    margin-right: auto;
  }

  /* ── Grid ── */
  .mem-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-auto-rows: 380px;
    gap: 1rem;
  }

  /* ── Skeleton ── */
  .mem-sk-card {
    border-radius: 1.25rem;
    overflow: hidden;
    background: #e7e5e4;
  }
  .mem-sk-featured {
    grid-column: span 2;
    grid-row: span 2;
  }
  .mem-sk-img {
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, #e7e5e4 25%, #d6d3d1 50%, #e7e5e4 75%);
    background-size: 200% 100%;
    animation: sk-shimmer 1.6s infinite;
  }
  @keyframes sk-shimmer {
    0%   { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }

  /* ── Card ── */
  .mem-card {
    display: block;
    border-radius: 1.25rem;
    overflow: hidden;
    text-decoration: none;
    position: relative;
    cursor: pointer;
  }
  .mem-card--featured {
    grid-column: span 2;
    grid-row: span 2;
  }

  .mem-card-img {
    position: relative;
    width: 100%;
    height: 100%;
    background: #292524;
  }
  .mem-card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
    transition: transform 0.65s cubic-bezier(0.25, 0.46, 0.45, 0.94), filter 0.4s ease;
    filter: brightness(0.88);
  }
  .mem-card:hover .mem-card-img img {
    transform: scale(1.06);
    filter: brightness(0.75);
  }
  .mem-card-fallback {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(145deg, #292524, #1c1917);
  }

  .mem-card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0,0,0,0.78) 0%,
      rgba(0,0,0,0.32) 45%,
      rgba(0,0,0,0.08) 75%,
      transparent 100%
    );
    transition: opacity 0.4s ease;
  }
  .mem-card:hover .mem-card-overlay {
    opacity: 1.15;
  }

  .mem-card-content {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 1.5rem;
    z-index: 2;
  }

  .mem-card-top {}
  .mem-card-years {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 500;
    color: rgba(255,255,255,0.65);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin: 0;
    background: rgba(255,255,255,0.1);
    backdrop-filter: blur(8px);
    padding: 4px 10px;
    border-radius: 20px;
    border: 1px solid rgba(255,255,255,0.15);
  }

  .mem-card-bottom {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .mem-card-name {
    font-size: 1.375rem;
    font-weight: 600;
    color: white;
    margin: 0;
    line-height: 1.2;
    letter-spacing: -0.01em;
    text-shadow: 0 1px 8px rgba(0,0,0,0.3);
  }
  .mem-card--featured .mem-card-name {
    font-size: 2rem;
  }
  .mem-card-especie {
    font-size: 0.8rem;
    color: rgba(255,255,255,0.55);
    margin: 0;
    font-weight: 400;
  }
  .mem-card-ded {
    font-size: 0.8125rem;
    color: rgba(255,255,255,0.75);
    line-height: 1.6;
    margin: 6px 0 0;
    font-style: italic;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .mem-card--featured .mem-card-ded {
    -webkit-line-clamp: 3;
    font-size: 0.9375rem;
  }
  .mem-card-cta {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 0.75rem;
    font-weight: 600;
    color: #aadfc2;
    margin-top: 10px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    opacity: 0;
    transform: translateY(4px);
    transition: opacity 0.3s ease, transform 0.3s ease, gap 0.2s ease;
  }
  .mem-card:hover .mem-card-cta {
    opacity: 1;
    transform: translateY(0);
    gap: 8px;
  }

  /* ── Empty ── */
  .mem-empty {
    flex-direction: column;
    align-items: center;
    gap: 14px;
    padding: 80px 24px;
    text-align: center;
  }
  .mem-empty-text {
    color: #a8a29e;
    font-size: 0.9375rem;
    margin: 0;
    max-width: 320px;
    line-height: 1.6;
  }

  /* ── CTA ── */
  .mem-cta {
    justify-content: center;
    margin-top: 2.5rem;
  }
  .mem-cta-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.875rem;
    font-weight: 600;
    color: #2d8a54;
    text-decoration: none;
    padding: 12px 24px;
    border: 1.5px solid #2d8a54;
    border-radius: 50px;
    transition: background 0.2s, color 0.2s, gap 0.2s;
  }
  .mem-cta-link:hover {
    background: #2d8a54;
    color: white;
    gap: 12px;
  }

  /* ── Reveal ── */
  .reveal-m {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.55s ease, transform 0.55s ease;
  }
  .reveal-m.is-visible { opacity: 1; transform: translateY(0); }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .mem-grid {
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: 300px;
    }
    .mem-sk-featured,
    .mem-card--featured {
      grid-column: span 2;
      grid-row: span 1;
    }
  }
  @media (max-width: 560px) {
    .mem-grid {
      grid-template-columns: 1fr;
      grid-auto-rows: 280px;
    }
    .mem-sk-featured,
    .mem-card--featured {
      grid-column: span 1;
      grid-row: span 1;
    }
    .mem-card--featured .mem-card-name { font-size: 1.5rem; }
  }

  @media (prefers-reduced-motion: reduce) {
    .reveal-m { opacity: 1; transform: none; transition: none; }
    .mem-card-img img { transition: none; }
    .mem-sk-img { animation: none; }
  }
</style>
