---
const sedes = [
  {
    nombre: 'Aires de Paz',
    subtitulo: 'Cementerio Parque · Crematorio Privado',
    direccion: 'Ruta A012 KM 1,2 — S2002 Pueblo Esther, Santa Fe',
    telefono: '341-3590030',
    horarios: [
      { dia: 'Lunes a Viernes', hora: '8:00 a 17:00' },
      { dia: 'Sábados y Domingos', hora: '9:00 a 17:00' },
      { dia: 'Feriados', hora: '9:00 a 17:00' },
    ],
    mapa: 'https://www.google.com/maps?q=Ruta+A012+KM+1.2+S2002+Pueblo+Esther+Santa+Fe+Argentina&output=embed',
    gmaps: 'https://maps.google.com/?q=Ruta+A012+KM+1.2+Pueblo+Esther+Santa+Fe+Argentina',
    emoji: '🌿',
  },
  {
    nombre: 'Oficina Comercial Rosario',
    subtitulo: 'Atención al público',
    direccion: 'San Lorenzo 2369, Rosario 2000',
    telefono: '341-4489449',
    horarios: [
      { dia: 'Lunes a Viernes', hora: '8:00 a 17:00' },
    ],
    mapa: 'https://www.google.com/maps?q=San+Lorenzo+2369+Rosario+Santa+Fe+Argentina&output=embed',
    gmaps: 'https://maps.google.com/?q=San+Lorenzo+2369+Rosario+Santa+Fe+Argentina',
    emoji: '🏢',
  },
]
---

<section id="ubicacion" class="py-16 md:py-24" style="background:#fafaf9;position:relative;overflow:hidden">

  <div style="max-width:72rem;margin:0 auto;padding:0 1.25rem">

    <div class="text-center mb-12 reveal-item">
      <p class="text-brand-600 text-xs md:text-sm font-medium tracking-widest uppercase mb-3">Dónde encontrarnos</p>
      <h2 class="font-display text-3xl md:text-4xl font-semibold text-stone-900 mb-4">Nuestras sedes</h2>
      <p class="text-stone-500 text-base leading-relaxed max-w-xl mx-auto">Estamos en Rosario y Pueblo Esther para acompañarte en cada momento.</p>
    </div>

    <div class="sedes-grid">
      {sedes.map((sede, i) => (
        <div class="sede-card reveal-item" style={`--reveal-delay:${i * 0.15}s`}>

          <!-- Mapa -->
          <div class="sede-mapa">
            <iframe
              src={sede.mapa}
              width="100%"
              height="100%"
              style="border:0"
              allowfullscreen
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title={`Mapa ${sede.nombre}`}
            ></iframe>
          </div>

          <!-- Info -->
          <div class="sede-info">
            <div style="margin-bottom:16px">
              <span style="font-size:1.5rem">{sede.emoji}</span>
              <h3 class="font-display" style="font-size:1.125rem;font-weight:600;color:#1c1917;margin:6px 0 2px">{sede.nombre}</h3>
              <p style="font-size:0.75rem;color:#a89f94;text-transform:uppercase;letter-spacing:0.06em;margin:0">{sede.subtitulo}</p>
            </div>

            <div style="display:flex;flex-direction:column;gap:10px;margin-bottom:20px">
              <!-- Dirección -->
              <div style="display:flex;align-items:flex-start;gap:10px">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#2d8a54" stroke-width="2" style="flex-shrink:0;margin-top:2px"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                <span style="font-size:0.875rem;color:#44403c;line-height:1.5">{sede.direccion}</span>
              </div>
              <!-- Teléfono -->
              <div style="display:flex;align-items:center;gap:10px">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#2d8a54" stroke-width="2" style="flex-shrink:0"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.25h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 8.37a16 16 0 0 0 6 6l.91-.91a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 21.73 16z"/></svg>
                <a href={`tel:+54${sede.telefono.replace(/\D/g,'')}`} style="font-size:0.875rem;color:#44403c;text-decoration:none;transition:color 0.2s" class="hover:text-brand-600">{sede.telefono}</a>
              </div>
            </div>

            <!-- Horarios -->
            <div style="background:#f0faf4;border:1px solid #d6f0e0;border-radius:12px;padding:14px 16px;margin-bottom:20px">
              <p style="font-size:0.6875rem;font-weight:600;color:#2d8a54;text-transform:uppercase;letter-spacing:0.08em;margin:0 0 10px">Horarios</p>
              {sede.horarios.map(h => (
                <div style="display:flex;justify-content:space-between;align-items:center;font-size:0.8125rem;color:#44403c;padding:3px 0">
                  <span>{h.dia}</span>
                  <span style="font-weight:600;color:#1c1917">{h.hora}</span>
                </div>
              ))}
            </div>

            <!-- CTA mapa -->
            <a
              href={sede.gmaps}
              target="_blank"
              rel="noopener noreferrer"
              style="display:flex;align-items:center;justify-content:center;gap:8px;width:100%;padding:11px;border-radius:9999px;border:1.5px solid #d6d3d1;color:#44403c;font-size:0.875rem;font-weight:500;text-decoration:none;transition:border-color 0.2s,color 0.2s"
              class="sede-cta"
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              Abrir en Google Maps
            </a>
          </div>

        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .sedes-grid { display:grid; grid-template-columns:1fr; gap:1.5rem; }
  @media(min-width:768px){ .sedes-grid { grid-template-columns:1fr 1fr; } }

  .sede-card { background:white; border-radius:1.5rem; border:1px solid #e7e5e4; overflow:hidden; box-shadow:0 1px 4px rgba(0,0,0,0.04); transition:transform 0.3s,box-shadow 0.3s,border-color 0.3s; display:flex; flex-direction:column; }
  .sede-card:hover { transform:translateY(-4px); box-shadow:0 0 0 1.5px #2d8a54, 0 8px 28px rgba(45,138,84,0.12); border-color:#aadfc2; }

  .sede-mapa { width:100%; height:220px; background:#f3f4f6; flex-shrink:0; }
  .sede-mapa iframe { display:block; }

  .sede-info { padding:1.5rem; display:flex; flex-direction:column; flex:1; }

  .sede-cta:hover { border-color:#2d8a54; color:#2d8a54; }

  .reveal-item { opacity:0; transform:translateY(28px); transition:opacity 0.55s ease calc(var(--reveal-delay,0s)),transform 0.55s ease calc(var(--reveal-delay,0s)); }
  .reveal-item.is-visible { opacity:1; transform:translateY(0); }

  @media(prefers-reduced-motion:reduce){ .reveal-item{opacity:1;transform:none;transition:none} .sede-card{transition:none} }
</style>

<script>
  const obs = new IntersectionObserver(es => es.forEach(e => { if(e.isIntersecting){e.target.classList.add('is-visible');obs.unobserve(e.target)} }), {threshold:0.1})
  document.querySelectorAll('#ubicacion .reveal-item').forEach(el => obs.observe(el))
</script>
