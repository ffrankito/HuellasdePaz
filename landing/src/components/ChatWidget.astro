---
const API_URL = import.meta.env.PUBLIC_CRM_URL ?? 'https://huellasde-paz.vercel.app'
---

<!-- Botón flotante -->
<button id="chat-toggle" aria-label="Abrir chat" style="
  position:fixed; bottom:28px; right:28px; z-index:1000;
  width:56px; height:56px; border-radius:50%; border:none; cursor:pointer;
  background:#1a8a9c; color:white;
  display:flex; align-items:center; justify-content:center;
  box-shadow:0 4px 20px rgba(26,138,156,0.45);
  transition:transform 0.2s, box-shadow 0.2s;
">
  <svg id="chat-icon-open" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
  </svg>
  <svg id="chat-icon-close" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" style="display:none">
    <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
  </svg>
</button>

<!-- Panel de chat -->
<div id="chat-panel" style="
  position:fixed; bottom:96px; right:28px; z-index:999;
  width:360px; height:500px;
  background:white; border-radius:20px;
  box-shadow:0 8px 40px rgba(0,0,0,0.15);
  border:1px solid #e5e7eb;
  display:none; flex-direction:column; overflow:hidden;
">

  <!-- Header -->
  <div style="background:#1a8a9c; padding:16px 18px; display:flex; align-items:center; gap:12px; flex-shrink:0">
    <div style="width:38px; height:38px; border-radius:50%; background:rgba(255,255,255,0.2); display:flex; align-items:center; justify-content:center; flex-shrink:0">
      <svg width="20" height="20" viewBox="0 0 40 40" fill="white">
        <ellipse cx="20" cy="26" rx="9" ry="7"/>
        <ellipse cx="10" cy="17" rx="4" ry="3.5" transform="rotate(-15 10 17)"/>
        <ellipse cx="17" cy="13" rx="3.5" ry="3" transform="rotate(-5 17 13)"/>
        <ellipse cx="24" cy="13" rx="3.5" ry="3" transform="rotate(5 24 13)"/>
        <ellipse cx="30" cy="17" rx="4" ry="3.5" transform="rotate(15 30 17)"/>
      </svg>
    </div>
    <div style="flex:1">
      <p style="font-size:14px; font-weight:700; color:white; margin:0; line-height:1.2">Aires de Paz</p>
      <p style="font-size:11px; color:rgba(255,255,255,0.75); margin:0">Respondemos al instante</p>
    </div>
    <div style="width:8px; height:8px; border-radius:50%; background:#4ade80; flex-shrink:0"></div>
  </div>

  <!-- Mensajes -->
  <div id="chat-messages" style="flex:1; overflow-y:auto; padding:16px; display:flex; flex-direction:column; gap:10px; scroll-behavior:smooth">
    <!-- Mensaje inicial del bot -->
    <div class="msg-bot" style="display:flex; gap:8px; align-items:flex-end">
      <div style="width:28px; height:28px; border-radius:50%; background:#f0f8fa; display:flex; align-items:center; justify-content:center; flex-shrink:0">
        <svg width="14" height="14" viewBox="0 0 40 40" fill="#1a8a9c">
          <ellipse cx="20" cy="26" rx="9" ry="7"/>
          <ellipse cx="10" cy="17" rx="4" ry="3.5" transform="rotate(-15 10 17)"/>
          <ellipse cx="17" cy="13" rx="3.5" ry="3" transform="rotate(-5 17 13)"/>
          <ellipse cx="24" cy="13" rx="3.5" ry="3" transform="rotate(5 24 13)"/>
          <ellipse cx="30" cy="17" rx="4" ry="3.5" transform="rotate(15 30 17)"/>
        </svg>
      </div>
      <div style="background:#f3f4f6; border-radius:16px 16px 16px 4px; padding:10px 14px; max-width:240px; font-size:13.5px; line-height:1.55; color:#111827">
        Hola 👋 Soy el asistente de <strong>Aires de Paz</strong>. ¿En qué te puedo ayudar hoy?
      </div>
    </div>
  </div>

  <!-- Input -->
  <div style="padding:12px 14px; border-top:1px solid #f3f4f6; display:flex; gap:8px; flex-shrink:0; background:white">
    <input
      id="chat-input"
      type="text"
      placeholder="Escribí tu consulta..."
      style="flex:1; padding:10px 14px; border-radius:24px; border:1px solid #e5e7eb; font-size:13.5px; outline:none; font-family:inherit; background:#f9fafb; color:#111827"
    />
    <button id="chat-send" style="
      width:38px; height:38px; border-radius:50%; border:none; cursor:pointer;
      background:#1a8a9c; color:white; display:flex; align-items:center; justify-content:center;
      flex-shrink:0; transition:background 0.15s;
    ">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/>
      </svg>
    </button>
  </div>
</div>

<style>
  #chat-toggle:hover { transform:scale(1.08); box-shadow:0 6px 28px rgba(26,138,156,0.55); }
  #chat-panel { animation:slideUp 0.25s ease; }
  @keyframes slideUp {
    from { opacity:0; transform:translateY(16px); }
    to   { opacity:1; transform:translateY(0); }
  }
  #chat-messages::-webkit-scrollbar { width:4px; }
  #chat-messages::-webkit-scrollbar-track { background:transparent; }
  #chat-messages::-webkit-scrollbar-thumb { background:#e5e7eb; border-radius:4px; }
  #chat-input:focus { border-color:#1a8a9c; background:white; }
  #chat-send:hover { background:#126070; }
</style>

<script define:vars={{ API_URL }}>
  const toggle    = document.getElementById('chat-toggle')
  const panel     = document.getElementById('chat-panel')
  const messages  = document.getElementById('chat-messages')
  const input     = document.getElementById('chat-input')
  const sendBtn   = document.getElementById('chat-send')
  const iconOpen  = document.getElementById('chat-icon-open')
  const iconClose = document.getElementById('chat-icon-close')

  let abierto = false
  let historial = []

  function abrirChat() {
    abierto = true
    panel.style.display = 'flex'
    iconOpen.style.display = 'none'
    iconClose.style.display = 'block'
    input.focus()
  }

  function cerrarChat() {
    abierto = false
    panel.style.display = 'none'
    iconOpen.style.display = 'block'
    iconClose.style.display = 'none'
  }

  toggle.addEventListener('click', () => abierto ? cerrarChat() : abrirChat())

  function agregarMensaje(texto, esUsuario) {
    const div = document.createElement('div')
    div.style.cssText = `display:flex; gap:8px; align-items:flex-end; ${esUsuario ? 'flex-direction:row-reverse' : ''}`

    if (!esUsuario) {
      const avatar = document.createElement('div')
      avatar.style.cssText = 'width:28px;height:28px;border-radius:50%;background:#f0f8fa;display:flex;align-items:center;justify-content:center;flex-shrink:0'
      avatar.innerHTML = `<svg width="14" height="14" viewBox="0 0 40 40" fill="#1a8a9c"><ellipse cx="20" cy="26" rx="9" ry="7"/><ellipse cx="10" cy="17" rx="4" ry="3.5" transform="rotate(-15 10 17)"/><ellipse cx="17" cy="13" rx="3.5" ry="3" transform="rotate(-5 17 13)"/><ellipse cx="24" cy="13" rx="3.5" ry="3" transform="rotate(5 24 13)"/><ellipse cx="30" cy="17" rx="4" ry="3.5" transform="rotate(15 30 17)"/></svg>`
      div.appendChild(avatar)
    }

    const burbuja = document.createElement('div')
    burbuja.style.cssText = esUsuario
      ? 'background:#1a8a9c;color:white;border-radius:16px 16px 4px 16px;padding:10px 14px;max-width:240px;font-size:13.5px;line-height:1.55'
      : 'background:#f3f4f6;color:#111827;border-radius:16px 16px 16px 4px;padding:10px 14px;max-width:240px;font-size:13.5px;line-height:1.55'
    burbuja.textContent = texto
    div.appendChild(burbuja)
    messages.appendChild(div)
    messages.scrollTop = messages.scrollHeight
    return burbuja
  }

  function mostrarTyping() {
    const div = document.createElement('div')
    div.id = 'typing-indicator'
    div.style.cssText = 'display:flex;gap:8px;align-items:flex-end'
    div.innerHTML = `
      <div style="width:28px;height:28px;border-radius:50%;background:#f0f8fa;display:flex;align-items:center;justify-content:center;flex-shrink:0">
        <svg width="14" height="14" viewBox="0 0 40 40" fill="#1a8a9c"><ellipse cx="20" cy="26" rx="9" ry="7"/><ellipse cx="10" cy="17" rx="4" ry="3.5" transform="rotate(-15 10 17)"/><ellipse cx="17" cy="13" rx="3.5" ry="3" transform="rotate(-5 17 13)"/><ellipse cx="24" cy="13" rx="3.5" ry="3" transform="rotate(5 24 13)"/><ellipse cx="30" cy="17" rx="4" ry="3.5" transform="rotate(15 30 17)"/></svg>
      </div>
      <div style="background:#f3f4f6;border-radius:16px 16px 16px 4px;padding:10px 14px;display:flex;gap:4px;align-items:center">
        <span style="width:6px;height:6px;border-radius:50%;background:#9ca3af;animation:dot 1.2s infinite 0s"></span>
        <span style="width:6px;height:6px;border-radius:50%;background:#9ca3af;animation:dot 1.2s infinite 0.2s"></span>
        <span style="width:6px;height:6px;border-radius:50%;background:#9ca3af;animation:dot 1.2s infinite 0.4s"></span>
      </div>
      <style>@keyframes dot{0%,80%,100%{transform:scale(0.7);opacity:0.5}40%{transform:scale(1);opacity:1}}</style>
    `
    messages.appendChild(div)
    messages.scrollTop = messages.scrollHeight
  }

  function quitarTyping() {
    document.getElementById('typing-indicator')?.remove()
  }

  async function enviar() {
    const texto = input.value.trim()
    if (!texto) return

    input.value = ''
    input.disabled = true
    sendBtn.disabled = true
    agregarMensaje(texto, true)
    historial.push({ role: 'user', content: texto })
    mostrarTyping()

    try {
      const res = await fetch(`${API_URL}/api/chat/publico`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ mensaje: texto, historial }),
      })
      const data = await res.json()
      quitarTyping()
      const respuesta = data.respuesta ?? 'Lo siento, hubo un error. Podés contactarnos por WhatsApp.'
      agregarMensaje(respuesta, false)
      historial.push({ role: 'assistant', content: respuesta })
    } catch {
      quitarTyping()
      agregarMensaje('No pude conectarme. Podés escribirnos por WhatsApp.', false)
    } finally {
      input.disabled = false
      sendBtn.disabled = false
      input.focus()
    }
  }

  sendBtn.addEventListener('click', enviar)
  input.addEventListener('keydown', e => { if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); enviar() } })
</script>
